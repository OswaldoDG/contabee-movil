<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="ContaBeeMovil.Services.Notifications.CustomToast">

    <Grid HeightRequest="100" VerticalOptions="End">
        <!-- Esquina amarilla inferior derecha -->
        <BoxView Color="#F4C611"
                 HeightRequest="100"
                 HorizontalOptions="End"
                 VerticalOptions="End"
                 Margin="0,0,0,0"/>

        <Border Stroke="#F4C611"
                StrokeThickness="2.5"
                BackgroundColor="White"
                Padding="18,14"
                HorizontalOptions="Fill"
                VerticalOptions="End"
                Margin="20,0,20,20"
                StrokeShape="RoundRectangle 18">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08" />
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">

                <!-- Ícono círculo negro con ! -->
                <Grid VerticalOptions="Center"
                      WidthRequest="28"
                      HeightRequest="28">
                    <Ellipse Fill="#1A1A1A"
                             WidthRequest="28"
                             HeightRequest="28"/>
                    <Label Text="!"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="16"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Grid>

                <!-- Mensaje -->
                <Label Grid.Column="1"
                       x:Name="MessageLabel"
                       Text="Email / Password incorrectos"
                       VerticalOptions="Center"
                       TextColor="#1A1A1A"
                       FontSize="15"
                       FontAttributes="Bold"
                       FontFamily="OpenSansSemiBold"/>

                <!-- Botón cerrar -->
                <ImageButton Grid.Column="2"
                             Source="close_icon.png"
                             HeightRequest="18"
                             WidthRequest="18"
                             Clicked="OnCloseClicked"
                             VerticalOptions="Center"
                             BackgroundColor="Transparent">
                    <ImageButton.Behaviors>
                        <toolkit:IconTintColorBehavior TintColor="#1A1A1A" />
                    </ImageButton.Behaviors>
                </ImageButton>

            </Grid>
        </Border>
    </Grid>
</toolkit:Popup>