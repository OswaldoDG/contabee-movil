<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Toolkit.Charts;assembly=Syncfusion.Maui.Toolkit"
             xmlns:vm="clr-namespace:ContaBeeMovil.Pages.Dashboard"
             x:Class="ContaBeeMovil.Views.ActividadView"
             x:DataType="vm:DashboardViewModel">

    <Border BackgroundColor="{toolkit:AppThemeResource Primary}"
            Stroke="Transparent"
            StrokeShape="RoundRectangle 20"
            Margin="8,8,8,8"
            Padding="5">
        <Border.Triggers>
            <DataTrigger TargetType="Border"
                         Binding="{Binding EstaCargando}"
                         Value="True">
                <Setter Property="BackgroundColor"
                        Value="{toolkit:AppThemeResource Background}" />
            </DataTrigger>
            <DataTrigger TargetType="Border"
                         Binding="{Binding MostrarError}"
                         Value="True">
                <Setter Property="BackgroundColor"
                        Value="{toolkit:AppThemeResource Background}" />
            </DataTrigger>
        </Border.Triggers>

        <!-- Outer grid for overlaying spinner/error on top of content -->
        <Grid>

            <!-- Main content: Grid con filas proporcionales para llenar la pantalla -->
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*"
                  RowSpacing="20"
                  IsVisible="{Binding MostrarContenido}"
                  Padding="0,10,0,20">

                <!-- Row 0: Header navegación de mes -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto,*,Auto"
                      VerticalOptions="Center">
                    <mi:MauiIcon Grid.Column="0"
                                 Icon="{mi:Material Icon=ChevronLeft}"
                                 IconColor="{toolkit:AppThemeResource Icon}"
                                 IconSize="30"
                                 BackgroundColor="Transparent"
                                 VerticalOptions="Center"
                                 Padding="2,2">
                        <mi:MauiIcon.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding MesAnteriorCommand}" />
                        </mi:MauiIcon.GestureRecognizers>
                    </mi:MauiIcon>

                    <HorizontalStackLayout Grid.Column="1"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Spacing="6">
                        <mi:MauiIcon Icon="{mi:Material Icon=Refresh}"
                                     IconColor="{toolkit:AppThemeResource Icon}"
                                     IconSize="20"
                                     BackgroundColor="Transparent"
                                     VerticalOptions="Center"
                                     Padding="0">
                            <mi:MauiIcon.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RefreshCommand}" />
                            </mi:MauiIcon.GestureRecognizers>
                        </mi:MauiIcon>
                        <Label Text="{Binding MesAnioTexto}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{toolkit:AppThemeResource PrimaryText}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <mi:MauiIcon Grid.Column="2"
                                 Icon="{mi:Material Icon=ChevronRight}"
                                 IconColor="{toolkit:AppThemeResource Icon}"
                                 IconSize="30"
                                 BackgroundColor="Transparent"
                                 VerticalOptions="Center"
                                 Padding="2,2">
                        <mi:MauiIcon.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding MesSiguienteCommand}" />
                        </mi:MauiIcon.GestureRecognizers>
                    </mi:MauiIcon>
                </Grid>

                <!-- Row 1: Banner sin actividad (condicional) -->
                <Border Grid.Row="1"
                        IsVisible="{Binding SinActividad}"
                        BackgroundColor="{toolkit:AppThemeResource SecondaryBackground}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 10"
                        Padding="12,6">
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <mi:MauiIcon Icon="{mi:Material Icon=InfoOutline}"
                                     IconColor="{toolkit:AppThemeResource SecondaryText}"
                                     IconSize="18"
                                     VerticalOptions="Center" />
                        <Label Text="Aún no tienes actividad registrada"
                               FontSize="13"
                               TextColor="{toolkit:AppThemeResource SecondaryText}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Row 2: Total Facturado -->
                <Border Grid.Row="2"
                        BackgroundColor="{toolkit:AppThemeResource Background}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 12"
                        Padding="16,6">
                    <Label HorizontalOptions="Center"
                           VerticalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="$ "
                                      FontSize="26"
                                      FontAttributes="Bold"
                                      TextColor="{toolkit:AppThemeResource PrimaryText}" />
                                <Span Text="{Binding TotalFacturado, StringFormat='{0:N2}'}"
                                      FontSize="26"
                                      FontAttributes="Bold"
                                      TextColor="{toolkit:AppThemeResource PrimaryText}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Border>

                <!-- Row 3: Créditos + Emitidas/Fallidas/Pendientes (flex wrap) -->
                <FlexLayout Grid.Row="3"
                            Direction="Row"
                            Wrap="Wrap"
                            JustifyContent="SpaceBetween"
                            AlignItems="Stretch">

                    <!-- Créditos Restantes -->
                    <Border FlexLayout.Basis="Auto"
                            BackgroundColor="{toolkit:AppThemeResource Background}"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 12"
                            Padding="16,6"
                            Margin="0,0,4,4">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="2" VerticalOptions="Center">
                            <Label Text="Restantes"
                                   FontSize="12"
                                   TextColor="{toolkit:AppThemeResource SecondaryText}"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding CreditosRestantes}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{toolkit:AppThemeResource PrimaryText}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Emitidas / Fallidas / Pendientes -->
                    <Border FlexLayout.Grow="1"
                            BackgroundColor="{toolkit:AppThemeResource Background}"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 12"
                            Padding="8,6"
                            Margin="0,0,0,4">
                        <Grid ColumnDefinitions="*,*,*" VerticalOptions="Center">
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                                <Label Text="Emitidas"
                                       FontSize="11"
                                       TextColor="{toolkit:AppThemeResource SecondaryText}"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding Emitidas}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <BoxView Grid.Column="0"
                                     WidthRequest="1"
                                     BackgroundColor="{toolkit:AppThemeResource Primary}"
                                     HorizontalOptions="End"
                                     VerticalOptions="Fill"
                                     Margin="0,3" />

                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                                <Label Text="Fallidas"
                                       FontSize="11"
                                       TextColor="{toolkit:AppThemeResource SecondaryText}"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding Declinadas}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <BoxView Grid.Column="1"
                                     WidthRequest="1"
                                     BackgroundColor="{toolkit:AppThemeResource Primary}"
                                     HorizontalOptions="End"
                                     VerticalOptions="Fill"
                                     Margin="0,3" />

                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                                <Label Text="Pendientes"
                                       FontSize="11"
                                       TextColor="{toolkit:AppThemeResource SecondaryText}"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding Pendientes}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </FlexLayout>

                <!-- Row 4: Gráfica — ocupa el espacio restante (*) -->
                <Border Grid.Row="4"
                        IsVisible="{Binding SinActividad, Converter={toolkit:InvertedBoolConverter}}"
                        BackgroundColor="{toolkit:AppThemeResource Background}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 12">
                    <Grid RowDefinitions="Auto,Auto,*">

                        <Label Grid.Row="0"
                               HorizontalOptions="Center"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{toolkit:AppThemeResource PrimaryText}"
                               Margin="0,6,0,0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Actividad " />
                                    <Span Text="{Binding MesNombreTexto}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <HorizontalStackLayout Grid.Row="1"
                                               HorizontalOptions="Center"
                                               Spacing="16"
                                               Margin="0,4">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Ellipse Fill="#FFC107" WidthRequest="10" HeightRequest="10" VerticalOptions="Center"/>
                                <Label Text="Emitidos" FontSize="11" VerticalOptions="Center"
                                       TextColor="{toolkit:AppThemeResource SecondaryText}" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Ellipse Fill="#E65100" WidthRequest="10" HeightRequest="10" VerticalOptions="Center"/>
                                <Label Text="Solicitados" FontSize="11" VerticalOptions="Center"
                                       TextColor="{toolkit:AppThemeResource SecondaryText}" />
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>

                        <chart:SfCartesianChart Grid.Row="2"
                                                Margin="8,0,8,8"
                                                BackgroundColor="Transparent">
                            <chart:SfCartesianChart.XAxes>
                                <chart:NumericalAxis Minimum="1"
                                                     Maximum="{Binding MaximoEjeX}"
                                                     Interval="5"
                                                     ShowMajorGridLines="False"
                                                     EdgeLabelsDrawingMode="Center">
                                    <chart:NumericalAxis.LabelStyle>
                                        <chart:ChartAxisLabelStyle FontSize="10" />
                                    </chart:NumericalAxis.LabelStyle>
                                </chart:NumericalAxis>
                            </chart:SfCartesianChart.XAxes>
                            <chart:SfCartesianChart.YAxes>
                                <chart:NumericalAxis Minimum="0"
                                                     Maximum="{Binding MaximoEjeY}"
                                                     Interval="1"
                                                     ShowMajorGridLines="True">
                                    <chart:NumericalAxis.LabelStyle>
                                        <chart:ChartAxisLabelStyle FontSize="10" LabelFormat="0" />
                                    </chart:NumericalAxis.LabelStyle>
                                </chart:NumericalAxis>
                            </chart:SfCartesianChart.YAxes>

                            <chart:ColumnSeries ItemsSource="{Binding DatosGrafica}"
                                                XBindingPath="Dia"
                                                YBindingPath="Emitidas"
                                                Fill="#FFC107"
                                                Width="0.4"
                                                Spacing="0.1" />

                            <chart:ColumnSeries ItemsSource="{Binding DatosGrafica}"
                                                XBindingPath="Dia"
                                                YBindingPath="Solicitadas"
                                                Fill="#E65100"
                                                Width="0.4"
                                                Spacing="0.1" />
                        </chart:SfCartesianChart>

                    </Grid>
                </Border>

            </Grid>

            <!-- Panel de error (overlay) -->
            <VerticalStackLayout IsVisible="{Binding MostrarError}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12">
                <mi:MauiIcon Icon="{mi:Material Icon=CloudOff}"
                             IconColor="{toolkit:AppThemeResource Primary}"
                             IconSize="48"
                             HorizontalOptions="Center" />
                <Label Text="{Binding MensajeError}"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       FontSize="14"
                       HorizontalTextAlignment="Center" />
                <Button Text="Reintentar"
                        Command="{Binding RefreshCommand}"
                        BackgroundColor="{toolkit:AppThemeResource Primary}"
                        TextColor="White"
                        CornerRadius="20"
                        Padding="24,8"
                        HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Spinner (overlay) -->
            <ActivityIndicator IsRunning="{Binding EstaCargando}"
                               IsVisible="{Binding EstaCargando}"
                               Color="{toolkit:AppThemeResource Primary}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center" />

        </Grid>
    </Border>

</ContentView>
