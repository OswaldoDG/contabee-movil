<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Toolkit.Charts;assembly=Syncfusion.Maui.Toolkit"
             xmlns:vm="clr-namespace:ContaBeeMovil.Pages.Dashboard"
             x:Class="ContaBeeMovil.Views.ActividadView"
             x:DataType="vm:DashboardViewModel"
             BackgroundColor="{toolkit:AppThemeResource Background}">

    <Grid Margin="8,1,8,8"
          Padding="5,1,5,0">

        <RefreshView x:Name="PullRefresh"
                     Command="{Binding PullRefreshCommand}"
                     IsRefreshing="{Binding EstaRefrescando}"
                     RefreshColor="{toolkit:AppThemeResource Icon}"
                     IsVisible="{Binding MostrarContenido}"
                     Background="{toolkit:AppThemeResource Background}">
          <ScrollView x:Name="MainScroll">
            <Grid RowDefinitions="Auto,Auto,Auto,*"
                  RowSpacing="10"
                  Padding="0,5,0,0"
                  HeightRequest="{Binding Source={x:Reference MainScroll}, Path=Height}">

                <Border Grid.Row="0"
                        IsVisible="{Binding SinActividad}"
                        BackgroundColor="{toolkit:AppThemeResource SecondaryBackground}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 10"
                        Padding="12,6">
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <mi:MauiIcon Icon="{mi:Material Icon=InfoOutline}"
                                     IconColor="{toolkit:AppThemeResource SecondaryText}"
                                     IconSize="18"
                                     VerticalOptions="Center" />
                        <Label Text="Aún no tienes actividad registrada"
                               FontSize="13"
                               TextColor="{toolkit:AppThemeResource SecondaryText}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <Border Grid.Row="1"
                        BackgroundColor="{toolkit:AppThemeResource Primary}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 10"
                        Padding="16,6">
                    <Label HorizontalOptions="Center"
                           VerticalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="$ "
                                      FontSize="26"
                                      FontAttributes="Bold"
                                      TextColor="{toolkit:AppThemeResource PrimaryText}" />
                                <Span Text="{Binding TotalFacturado, StringFormat='{0:N2}'}"
                                      FontSize="26"
                                      FontAttributes="Bold"
                                      TextColor="{toolkit:AppThemeResource PrimaryText}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Border>

                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*,*,*"
                      ColumnSpacing="5">

                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Border BackgroundColor="{toolkit:AppThemeResource Primary}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 10"
                                Padding="1,10"
                                HorizontalOptions="Fill">
                            <Label Text="{Binding CreditosRestantes}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{toolkit:AppThemeResource PrimaryText}"
                                   HorizontalOptions="Center" />
                        </Border>
                        <Label Text="Restantes"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource Primary}}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource Gray600}}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 10"
                                Padding="8,10"
                                HorizontalOptions="Fill">
                            <Label Text="{Binding Emitidas}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}"
                                   HorizontalOptions="Center" />
                        </Border>
                        <Label Text="Emitidas"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource Primary}}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" Spacing="4">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource Gray600}}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 10"
                                Padding="8,10"
                                HorizontalOptions="Fill">
                            <Label Text="{Binding Declinadas}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}"
                                   HorizontalOptions="Center" />
                        </Border>
                        <Label Text="Fallidas"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource Primary}}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="3" Spacing="4">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource OffBlack}, Dark={StaticResource Gray600}}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 10"
                                Padding="8,10"
                                HorizontalOptions="Fill">
                            <Label Text="{Binding Pendientes}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}"
                                   HorizontalOptions="Center" />
                        </Border>
                        <Label Text="Pendientes"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource Primary}}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                </Grid>

                <Border Grid.Row="3"
                        IsVisible="{Binding SinActividad, Converter={toolkit:InvertedBoolConverter}}"
                        BackgroundColor="{toolkit:AppThemeResource Background}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 10"
                        Margin="0,3,0,3">
                    <Grid RowDefinitions="Auto,Auto,*">

                        <Label Grid.Row="0"
                               HorizontalOptions="Center"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{toolkit:AppThemeResource PrimaryText}"
                               Margin="0,0,0,0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Actividad " />
                                    <Span Text="{Binding MesNombreTexto}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <HorizontalStackLayout Grid.Row="1"
                                               HorizontalOptions="Center"
                                               Spacing="16"
                                               Margin="0,4">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Ellipse Fill="#FFC107" WidthRequest="10" HeightRequest="10" VerticalOptions="Center"/>
                                <Label Text="Emitidos" FontSize="11" VerticalOptions="Center"
                                       TextColor="{toolkit:AppThemeResource SecondaryText}" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Ellipse Fill="#E65100" WidthRequest="10" HeightRequest="10" VerticalOptions="Center"/>
                                <Label Text="Solicitados" FontSize="11" VerticalOptions="Center"
                                       TextColor="{toolkit:AppThemeResource SecondaryText}" />
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>

                        <chart:SfCartesianChart Grid.Row="2"
                                                Margin="8,0,8,8"
                                                BackgroundColor="Transparent">
                            <chart:SfCartesianChart.XAxes>
                                <chart:NumericalAxis Minimum="1"
                                                     Maximum="{Binding MaximoEjeX}"
                                                     Interval="5"
                                                     ShowMajorGridLines="False"
                                                     EdgeLabelsDrawingMode="Center">
                                    <chart:NumericalAxis.LabelStyle>
                                        <chart:ChartAxisLabelStyle FontSize="10" />
                                    </chart:NumericalAxis.LabelStyle>
                                </chart:NumericalAxis>
                            </chart:SfCartesianChart.XAxes>
                            <chart:SfCartesianChart.YAxes>
                                <chart:NumericalAxis Minimum="0"
                                                     Maximum="{Binding MaximoEjeY}"
                                                     Interval="1"
                                                     ShowMajorGridLines="True">
                                    <chart:NumericalAxis.LabelStyle>
                                        <chart:ChartAxisLabelStyle FontSize="10" LabelFormat="0" />
                                    </chart:NumericalAxis.LabelStyle>
                                </chart:NumericalAxis>
                            </chart:SfCartesianChart.YAxes>

                            <chart:ColumnSeries ItemsSource="{Binding DatosGrafica}"
                                                XBindingPath="Dia"
                                                YBindingPath="Emitidas"
                                                Fill="#FFC107"
                                                Width="0.4"
                                                Spacing="0.1" />

                            <chart:ColumnSeries ItemsSource="{Binding DatosGrafica}"
                                                XBindingPath="Dia"
                                                YBindingPath="Solicitadas"
                                                Fill="#E65100"
                                                Width="0.4"
                                                Spacing="0.1" />
                        </chart:SfCartesianChart>

                    </Grid>
                </Border>

            </Grid>
          </ScrollView>
        </RefreshView>

        <!-- Panel de error (overlay) -->
        <VerticalStackLayout IsVisible="{Binding MostrarError}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="12">
            <mi:MauiIcon Icon="{mi:Material Icon=CloudOff}"
                         IconColor="{toolkit:AppThemeResource Primary}"
                         IconSize="48"
                         HorizontalOptions="Center" />
            <Label Text="{Binding MensajeError}"
                   TextColor="{toolkit:AppThemeResource PrimaryText}"
                   FontSize="14"
                   HorizontalTextAlignment="Center" />
            <Button Text="Reintentar"
                    Command="{Binding RefreshCommand}"
                    BackgroundColor="{toolkit:AppThemeResource Primary}"
                    TextColor="White"
                    CornerRadius="20"
                    Padding="24,8"
                    HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Spinner (overlay) -->
        <ActivityIndicator IsRunning="{Binding EstaCargando}"
                           IsVisible="{Binding EstaCargando}"
                           Color="{toolkit:AppThemeResource Primary}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />

    </Grid>

</ContentView>
