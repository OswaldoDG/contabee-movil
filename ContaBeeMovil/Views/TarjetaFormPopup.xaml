<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="ContaBeeMovil.Views.TarjetaFormPopup"
               CanBeDismissedByTappingOutsideOfPopup="False"
               Background="Transparent">

    <Border BackgroundColor="{toolkit:AppThemeResource SecondaryBackground}"
            Stroke="Transparent"
            StrokeShape="RoundRectangle 20"
            Padding="24,20"
            WidthRequest="340">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,4" Radius="16" Opacity="0.35"/>
        </Border.Shadow>

        <VerticalStackLayout Spacing="16">

            <!-- Título -->
            <Label x:Name="LblTitulo"
                   Text="Crear Tarjeta"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{toolkit:AppThemeResource PrimaryText}"
                   HorizontalOptions="Center"/>

            <BoxView HeightRequest="1"
                     BackgroundColor="{toolkit:AppThemeResource Accent1}"
                     HorizontalOptions="Fill"/>

            <!-- Alias -->
            <Border BackgroundColor="{toolkit:AppThemeResource Alternate}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 12"
                    Padding="16,4">
                <Entry x:Name="EntryAlias"
                       Placeholder="Alias"
                       PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       BackgroundColor="Transparent"/>
            </Border>

            <!-- Últimos 4 dígitos -->
            <Border BackgroundColor="{toolkit:AppThemeResource Alternate}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 12"
                    Padding="16,4">
                <Entry x:Name="EntryDigitos"
                       Placeholder="Últimos 4 Dígitos"
                       PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       BackgroundColor="Transparent"
                       Keyboard="Numeric"
                       MaxLength="4"
                       TextChanged="OnDigitosChanged"/>
            </Border>

            <Label x:Name="LblContador"
                   Text="0/4"
                   TextColor="{toolkit:AppThemeResource SecondaryText}"
                   FontSize="12"
                   HorizontalOptions="End"
                   Margin="0,-10,0,0"/>

            <!-- Validación -->
            <Label x:Name="LblError"
                   Text=""
                   TextColor="{toolkit:AppThemeResource Error}"
                   FontSize="12"
                   IsVisible="False"
                   HorizontalOptions="Center"/>

            <!-- Botones -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,4,0,0">
                <Button Grid.Column="0"
                        Text="Cancelar"
                        BackgroundColor="{toolkit:AppThemeResource Alternate}"
                        TextColor="{toolkit:AppThemeResource PrimaryText}"
                        CornerRadius="12"
                        HeightRequest="48"
                        Clicked="OnCancelar"/>
                <Button x:Name="BtnAccion"
                        Grid.Column="1"
                        Text="Agregar"
                        BackgroundColor="{toolkit:AppThemeResource Secondary}"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="48"
                        FontAttributes="Bold"
                        Clicked="OnAceptar"/>
            </Grid>

        </VerticalStackLayout>
    </Border>

</toolkit:Popup>
