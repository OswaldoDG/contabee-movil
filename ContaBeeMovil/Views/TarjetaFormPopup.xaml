<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="ContaBeeMovil.Views.TarjetaFormPopup"
               BackgroundColor="Transparent"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <Border BackgroundColor="{AppThemeBinding Light=#fafafa, Dark=#505050}"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            StrokeShape="RoundRectangle 12"
            Stroke="{AppThemeBinding Light=#d8d9db, Dark=#7a7a7a}"
            StrokeThickness="1"
            Padding="18"
            WidthRequest="360">

        <VerticalStackLayout Spacing="12">

            <Label x:Name="LblTitulo"
                   Text="Crear Tarjeta"
                   FontAttributes="Bold"
                   FontSize="20"
                   HorizontalOptions="Center"
                   TextColor="{toolkit:AppThemeResource PrimaryText}" />

            <Entry x:Name="EntryAlias"
                   Placeholder="Alias"
                   HeightRequest="44"
                   TextColor="{toolkit:AppThemeResource PrimaryText}"
                   PlaceholderColor="{toolkit:AppThemeResource SecondaryText}" />

            <Entry x:Name="EntryDigitos"
                   Placeholder="Últimos 4 Dígitos"
                   Keyboard="Numeric"
                   MaxLength="4"
                   HeightRequest="44"
                   TextColor="{toolkit:AppThemeResource PrimaryText}"
                   PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                   TextChanged="OnDigitosChanged" />

            <Label x:Name="LblContador"
                   Text="0/4"
                   HorizontalOptions="End"
                   TextColor="{toolkit:AppThemeResource SecondaryText}">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup x:Name="DigitosValidation">
                        <VisualState x:Name="Empty">
                            <VisualState.Setters>
                                <Setter Property="TextColor" Value="{toolkit:AppThemeResource SecondaryText}" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Valid">
                            <VisualState.Setters>
                                <Setter Property="TextColor" Value="{toolkit:AppThemeResource Success}" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Invalid">
                            <VisualState.Setters>
                                <Setter Property="TextColor" Value="{toolkit:AppThemeResource Error}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
            </Label>

            <Label x:Name="LblError"
                   Text=""
                   TextColor="{toolkit:AppThemeResource Error}"
                   FontSize="12"
                   IsVisible="False"
                   HorizontalOptions="Center" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Cancelar"
                        BackgroundColor="Transparent"
                        BorderColor="{toolkit:AppThemeResource Accent1}"
                        BorderWidth="1"
                        TextColor="{toolkit:AppThemeResource PrimaryText}"
                        CornerRadius="10"
                        HeightRequest="44"
                        Clicked="OnCancelar" />
                <Button x:Name="BtnAccion"
                        Grid.Column="1"
                        Text="Agregar"
                        BackgroundColor="{toolkit:AppThemeResource Primary}"
                        TextColor="{toolkit:AppThemeResource PrimaryText}"
                        CornerRadius="10"
                        HeightRequest="44"
                        Clicked="OnAceptar">
                    <Button.Triggers>
                        <Trigger TargetType="Button" Property="IsEnabled" Value="False">
                            <Setter Property="BackgroundColor" Value="{toolkit:AppThemeResource Disabled}" />
                            <Setter Property="TextColor"       Value="{toolkit:AppThemeResource SecondaryText}" />
                            <Setter Property="Opacity"         Value="1" />
                        </Trigger>
                    </Button.Triggers>
                </Button>
            </Grid>

        </VerticalStackLayout>
    </Border>

</toolkit:Popup>
