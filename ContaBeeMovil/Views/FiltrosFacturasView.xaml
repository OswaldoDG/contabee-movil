<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:f="clr-namespace:Fonts"
             x:Class="ContaBeeMovil.Views.FiltrosFacturasView">

    <Border Style="{StaticResource CardStyle}" Padding="12">

        <VerticalStackLayout Spacing="8">

            <!-- Panel de filtros (colapsable) -->
            <VerticalStackLayout x:Name="PanelFiltros" Spacing="8">

                <!-- Fila 1: Año | Mes -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Border Grid.Column="0"
                            BackgroundColor="{toolkit:AppThemeResource Background}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            Padding="4,0">
                        <Picker x:Name="PickerAnio"
                                Title="Año"
                                FontSize="14"
                                TextColor="{toolkit:AppThemeResource PrimaryText}"
                                TitleColor="{toolkit:AppThemeResource SecondaryText}"
                                BackgroundColor="Transparent"
                                HeightRequest="44" />
                    </Border>
                    <Border Grid.Column="1"
                            BackgroundColor="{toolkit:AppThemeResource Background}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            Padding="4,0">
                        <Picker x:Name="PickerMes"
                                Title="Mes"
                                FontSize="14"
                                TextColor="{toolkit:AppThemeResource PrimaryText}"
                                TitleColor="{toolkit:AppThemeResource SecondaryText}"
                                BackgroundColor="Transparent"
                                HeightRequest="44" />
                    </Border>
                </Grid>

                <!-- Fila 2: Estado | Creador -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Border Grid.Column="0"
                            BackgroundColor="{toolkit:AppThemeResource Background}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            Padding="4,0">
                        <Picker x:Name="PickerEstado"
                                Title="Estado"
                                FontSize="14"
                                TextColor="{toolkit:AppThemeResource PrimaryText}"
                                TitleColor="{toolkit:AppThemeResource SecondaryText}"
                                BackgroundColor="Transparent"
                                HeightRequest="44" />
                    </Border>
                    <Border Grid.Column="1"
                            BackgroundColor="{toolkit:AppThemeResource Background}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            Padding="4,0">
                        <Picker x:Name="PickerCreador"
                                Title="Creador"
                                FontSize="14"
                                TextColor="{toolkit:AppThemeResource PrimaryText}"
                                TitleColor="{toolkit:AppThemeResource SecondaryText}"
                                BackgroundColor="Transparent"
                                HeightRequest="44" />
                    </Border>
                </Grid>

                <!-- Fila 3: Envío | Tipo -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Border Grid.Column="0"
                            BackgroundColor="{toolkit:AppThemeResource Background}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            Padding="4,0">
                        <Picker x:Name="PickerEnvio"
                                Title="Envío"
                                FontSize="14"
                                TextColor="{toolkit:AppThemeResource PrimaryText}"
                                TitleColor="{toolkit:AppThemeResource SecondaryText}"
                                BackgroundColor="Transparent"
                                HeightRequest="44" />
                    </Border>
                    <Border Grid.Column="1"
                            BackgroundColor="{toolkit:AppThemeResource Background}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            Padding="4,0">
                        <Picker x:Name="PickerTipo"
                                Title="Tipo"
                                FontSize="14"
                                TextColor="{toolkit:AppThemeResource PrimaryText}"
                                TitleColor="{toolkit:AppThemeResource SecondaryText}"
                                BackgroundColor="Transparent"
                                HeightRequest="44" />
                    </Border>
                </Grid>

                <!-- Fila 4: RFC contiene (ancho completo) -->
                <Border BackgroundColor="{toolkit:AppThemeResource Background}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1"
                        Stroke="{toolkit:AppThemeResource Accent1}"
                        Padding="12,0">
                    <Entry x:Name="EntryRfc"
                           Placeholder="rfc contiene"
                           FontSize="14"
                           PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                           TextColor="{toolkit:AppThemeResource PrimaryText}"
                           BackgroundColor="Transparent"
                           HeightRequest="44"
                           Keyboard="Text" />
                </Border>

            </VerticalStackLayout>

            <!-- Barra de acción (siempre visible) -->
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                  ColumnSpacing="8"
                  VerticalOptions="Center">

                <!-- Etiqueta período actual -->
                <Label x:Name="LabelPeriodo"
                       Grid.Column="0"
                       Style="{StaticResource Body2Strong}"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLabelPeriodoTapped"/>
                    </Label.GestureRecognizers>
                </Label>

                <!-- Botón dirección de orden -->
                <Border Grid.Column="1"
                        Style="{StaticResource CircleIconButton}"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnToggleOrden" />
                    </Border.GestureRecognizers>
                    <Label x:Name="IconOrden"
                           Style="{StaticResource CircleIconLabel}"
                           Text="{x:Static f:FluentUI.arrow_sort_down_lines_20_regular}" />
                </Border>

                <!-- Picker campo de orden -->
                <Border Grid.Column="2"
                        BackgroundColor="{toolkit:AppThemeResource Background}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1"
                        Stroke="{toolkit:AppThemeResource Accent1}"
                        Padding="4,0"
                        VerticalOptions="Center">
                    <Picker x:Name="PickerOrden"
                            FontSize="13"
                            TextColor="{toolkit:AppThemeResource PrimaryText}"
                            BackgroundColor="Transparent"
                            HeightRequest="40" />
                </Border>

                <!-- Botón buscar (círculo amarillo) -->
                <Border Grid.Column="3"
                        BackgroundColor="{toolkit:AppThemeResource Primary}"
                        StrokeShape="RoundRectangle 22"
                        StrokeThickness="0"
                        HeightRequest="44"
                        WidthRequest="44"
                        Padding="0"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBuscarTapped" />
                    </Border.GestureRecognizers>
                    <Label Text="{x:Static f:FluentUI.search_20_regular}"
                           FontFamily="{x:Static f:FluentUI.FontFamily}"
                           FontSize="20"
                           TextColor="{toolkit:AppThemeResource PrimaryText}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <!-- Botón expandir/colapsar -->
                <Border Grid.Column="4"
                        Style="{StaticResource CircleIconButton}"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnToggleExpandir" />
                    </Border.GestureRecognizers>
                    <Label x:Name="IconExpandir"
                           Style="{StaticResource CircleIconLabel}"
                           Text="{x:Static f:FluentUI.chevron_up_20_regular}" />
                </Border>

            </Grid>

        </VerticalStackLayout>

    </Border>

</ContentView>
