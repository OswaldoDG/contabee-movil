<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:converters="clr-namespace:ContaBeeMovil.Converters"
             xmlns:transcript="clr-namespace:Contabee.Api.Transcript;assembly=Contabee.Api"
             x:Class="ContaBeeMovil.Views.LoteCapturaCardView"
             Padding="0">

    <ContentView.Resources>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacity" />
        <converters:BoolToColorConverter x:Key="BoolToColor" />
        <converters:EstadoBadgeTextoConverter x:Key="BadgeTexto" />
        <converters:EstadoBadgeColorConverter x:Key="BadgeColor" />
        <converters:EstadoBadgeTextColorConverter x:Key="BadgeTextColor" />
        <converters:TipoProcesoCapturaIconConverter x:Key="TipoIcon" />
        <converters:ClaveFormaPagoIconConverter x:Key="FormaPagoIcon" />
        <converters:ClaveFormaPagoEsTarjetaConverter x:Key="EsTarjeta" />
        <converters:UsoCfdiOErrorConverter x:Key="UsoCfdiOError" />
        <converters:NombreInicialesConverter x:Key="NombreIniciales" />
        <converters:FormaPagoConTerminacionConverter x:Key="FormaPagoConTerminacion" />
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmpty" />
    </ContentView.Resources>

    <Border Style="{StaticResource ElevatedCard}"
            Margin="5,4"
            Padding="0">

        <Grid ColumnDefinitions="Auto,*,Auto">

            <!-- ── COLUMNA IZQUIERDA: Consecutivo, Iniciales, Cámara ─────────────────────────────────────── -->
            <Grid Grid.Column="0" 
                  RowDefinitions="*,*,*"
                  Padding="10"
                  VerticalOptions="Fill"
                  HorizontalOptions="Center"
                  WidthRequest="52">

                <!-- Consecutivo -->
                <Label Grid.Row="0"
                       Text="{Binding Consecutivo}"
                       Style="{StaticResource Body2Strong}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

                <!-- Iniciales NombreCreador -->
                <Label Grid.Row="1"
                       Text="{Binding Datos.NombreCreador, Converter={StaticResource NombreIniciales}}"
                       Style="{StaticResource Body2Strong}"
                       FontSize="14"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

                <!-- Cámara -->
                <Grid Grid.Row="2"
                      HeightRequest="32" WidthRequest="32" 
                      VerticalOptions="Center"
                      HorizontalOptions="Center">
                    <Border x:Name="BtnCamaraLeft" Style="{StaticResource CircleIconButton}"
                            HeightRequest="32" WidthRequest="32"
                            StrokeThickness="0"
                            VerticalOptions="Center"
                            HorizontalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDescargarImagen" />
                        </Border.GestureRecognizers>
                        <mi:MauiIcon Icon="{mi:Material Icon=PhotoCamera}"
                                     Style="{StaticResource CircleIconLabel}"
                                     IconSize="18"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center" />
                    </Border>
                    <ActivityIndicator x:Name="SpinnerCamaraLeft"
                                       IsVisible="False" IsRunning="False"
                                       Color="{toolkit:AppThemeResource Primary}"
                                       WidthRequest="20" HeightRequest="20"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                </Grid>
            </Grid>

            <!-- ── COLUMNA CENTRAL: Información principal alineada y centrada ─────────────────────────────────────── -->
            <VerticalStackLayout Grid.Column="1" 
                                Spacing="8" 
                                Padding="10,10,10,10"
                                VerticalOptions="Center"
                                HorizontalOptions="Fill">

                <!-- Fila 1: Fecha (pill) | Forma de pago con terminación (pill) -->
                <FlexLayout Direction="Row"
                           Wrap="Wrap"
                           AlignItems="Center"
                           JustifyContent="SpaceBetween">
                    <Border StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            BackgroundColor="Transparent"
                            Padding="8,2"
                            Margin="0,0,8,2"
                            VerticalOptions="Center">
                        <Label Text="{Binding Datos.FechaCreacion, StringFormat='{0:d/M/yyyy HH:mm}'}"
                               Style="{StaticResource Caption1}"
                               VerticalOptions="Center"
                               LineBreakMode="NoWrap" />
                    </Border>
                    <Border StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            BackgroundColor="Transparent"
                            Padding="8,2"
                            Margin="0,0,0,2"
                            VerticalOptions="Center">
                        <Label Style="{StaticResource Caption1}"
                               VerticalOptions="Center"
                               LineBreakMode="NoWrap">
                            <Label.Text>
                                <MultiBinding Converter="{StaticResource FormaPagoConTerminacion}">
                                    <Binding Path="Datos.ClaveFormaPago" />
                                    <Binding Path="Datos.TerminacionMedioPago" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                    </Border>
                </FlexLayout>

                <!-- Fila 2: Badge estado/monto -->
                <Border BackgroundColor="{Binding Datos, Converter={StaticResource BadgeColor}}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 10"
                        Padding="16,6"
                        HorizontalOptions="Fill"
                        VerticalOptions="Center">
                    <Label Text="{Binding Datos, Converter={StaticResource BadgeTexto}}"
                           TextColor="{Binding Datos, Converter={StaticResource BadgeTextColor}}"
                           Style="{StaticResource Body2Strong}"
                           HorizontalTextAlignment="Center"
                           VerticalOptions="Center"
                           LineBreakMode="TailTruncation" />
                </Border>

                <!-- Fila 3: UsoCfdi o Motivo + RFC Receptor (apilados verticalmente) -->
                <VerticalStackLayout Spacing="4">
                    <!-- UsoCFDI o Error -->
                    <Border StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            BackgroundColor="Transparent"
                            Padding="8,4"
                            HorizontalOptions="Fill">
                        <Label Text="{Binding Datos, Converter={StaticResource UsoCfdiOError}}"
                               Style="{StaticResource Caption1}"
                               LineBreakMode="TailTruncation"
                               VerticalOptions="Center"
                               HorizontalOptions="Start" />
                    </Border>

                    <!-- RFC RfcEmisor -->
                    <Border StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            BackgroundColor="Transparent"
                            Padding="8,4"
                            HorizontalOptions="Fill"
                            IsVisible="{Binding Datos.RfcEmisor, Converter={StaticResource StringNotEmpty}}">
                        <Label Text="{Binding Datos.RfcEmisor}"
                               Style="{StaticResource Caption1}"
                               VerticalOptions="Center"
                               HorizontalOptions="Start"
                               LineBreakMode="NoWrap" />
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>

            <!-- ── Columna derecha: PDF / XML apilados (área azul - no tocar) ─────────────────────── -->
            <Border Grid.Column="2"
                    BackgroundColor="{toolkit:AppThemeResource Alternate}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 0,16,0,16"
                    Padding="6,10"
                    WidthRequest="52"
                    VerticalOptions="Fill">
                <VerticalStackLayout Spacing="8"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">
                    <!-- PDF -->
                    <Grid>
                        <Border x:Name="BtnPdf" Style="{StaticResource CircleIconButton}"
                                HeightRequest="42" WidthRequest="42"
                                StrokeThickness="0"
                                IsEnabled="{Binding Datos.TienePdf}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDescargarPdf" />
                            </Border.GestureRecognizers>
                            <mi:MauiIcon Icon="{mi:Material Icon=PictureAsPdf}"
                                         Style="{StaticResource CircleIconLabel}"
                                         IconSize="20"
                                         IconColor="{Binding Datos.TienePdf, Converter={StaticResource BoolToColor}}" />
                        </Border>
                        <ActivityIndicator x:Name="SpinnerPdf"
                                           IsVisible="False" IsRunning="False"
                                           Color="{toolkit:AppThemeResource Primary}"
                                           WidthRequest="20" HeightRequest="20"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                    </Grid>
                    <!-- XML -->
                    <Grid>
                        <Border x:Name="BtnXml" Style="{StaticResource CircleIconButton}"
                                HeightRequest="42" WidthRequest="42"
                                StrokeThickness="0"
                                IsEnabled="{Binding Datos.TieneXml}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDescargarXml" />
                            </Border.GestureRecognizers>
                            <mi:MauiIcon Icon="{mi:Material Icon=Description}"
                                         Style="{StaticResource CircleIconLabel}"
                                         IconSize="20"
                                         IconColor="{Binding Datos.TieneXml, Converter={StaticResource BoolToColor}}" />
                        </Border>
                        <ActivityIndicator x:Name="SpinnerXml"
                                           IsVisible="False" IsRunning="False"
                                           Color="{toolkit:AppThemeResource Primary}"
                                           WidthRequest="20" HeightRequest="20"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </Grid>

    </Border>

</ContentView>
