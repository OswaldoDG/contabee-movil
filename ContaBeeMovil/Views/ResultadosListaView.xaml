<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:f="clr-namespace:Fonts"
             x:Class="ContaBeeMovil.Views.ResultadosListaView">

    <Grid RowDefinitions="*,Auto">

        <!-- Lista de resultados -->
        <CollectionView x:Name="Lista"
                        Grid.Row="0"
                        BackgroundColor="{toolkit:AppThemeResource Accent1}"/>

        <!-- Overlay de carga -->
        <Grid x:Name="LoadingOverlay"
              Grid.Row="0"
              IsVisible="False"
              BackgroundColor="Transparent"
              InputTransparent="False">
            <ActivityIndicator IsRunning="True"
                               Color="{toolkit:AppThemeResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               WidthRequest="48"
                               HeightRequest="48" />
        </Grid>

        <!-- Contenedor con fondo para la zona inferior -->
        <Border Grid.Row="1" x:Name="BarraPaginacion"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 1,1,0,0"
                BackgroundColor="{toolkit:AppThemeResource Background}"
                Padding="0"
                IsVisible="False">
                <Border.Shadow>
                <Shadow Brush="Black"
                        Radius="1"
                        Opacity="0.1"
                        Offset="0,-1" />
            </Border.Shadow>
                <!-- Barra de paginación -->
                <Grid Grid.Row="1" 
                      ColumnDefinitions="*,Auto,*"
                      Padding="12,8"
                      HorizontalOptions="Fill"
                      VerticalOptions="Center">

                    <!-- Espacio izquierdo -->
                    <BoxView Grid.Column="0" IsVisible="False" />

                    <!-- Controles de paginación centrados -->
                    <HorizontalStackLayout Grid.Column="1"
                                          Spacing="18"
                                          HorizontalOptions="Center"
                                          VerticalOptions="Center">

                        <!-- Botón página anterior -->
                        <Border x:Name="BtnAnterior"
                                StrokeShape="RoundRectangle 22"
                                HeightRequest="44"
                                WidthRequest="44"
                                StrokeThickness="2"
                                Stroke="{toolkit:AppThemeResource Primary}"
                                BackgroundColor="Transparent"
                                Padding="0"
                                VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAnteriorTapped" />
                            </Border.GestureRecognizers>
                            <Label Text="{x:Static f:FluentUI.chevron_left_20_regular}"
                                   FontFamily="FluentUI"
                                   FontSize="20"
                                   TextColor="{toolkit:AppThemeResource Primary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Página actual con formato "1-[total]" -->
                        <Label x:Name="LabelPagina"
                            Style="{StaticResource Body1Strong}"
                            FontSize="16"
                            VerticalOptions="Center"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            WidthRequest="60" />

                        <!-- Botón página siguiente -->
                        <Border x:Name="BtnSiguiente"
                                StrokeShape="RoundRectangle 22"
                                HeightRequest="44"
                                WidthRequest="44"
                                StrokeThickness="2"
                                Stroke="{toolkit:AppThemeResource Primary}"
                                BackgroundColor="Transparent"
                                Padding="0"
                                VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSiguienteTapped" />
                            </Border.GestureRecognizers>
                            <Label Text="{x:Static f:FluentUI.chevron_right_20_regular}"
                                   FontFamily="FluentUI"
                                   FontSize="20"
                                   TextColor="{toolkit:AppThemeResource Primary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                    </HorizontalStackLayout>

                    <!-- Botón de cámara a la derecha -->
                    <Border x:Name="BtnCaptura"
                            Grid.Column="2"
                            WidthRequest="44" HeightRequest="44"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            BackgroundColor="{toolkit:AppThemeResource Primary}"
                            VerticalOptions="Center"
                            HorizontalOptions="End"
                            Margin="0,0,8,0"
                            IsVisible="False">
                        <Border.Shadow>
                            <Shadow Brush="{toolkit:AppThemeResource Shadow}" Offset="0,2" Radius="4" Opacity="0.4" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCapturaTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="{x:Static f:FluentUI.camera_20_regular}"
                               FontFamily="FluentUI"
                               FontSize="22"
                               TextColor="{toolkit:AppThemeResource PrimaryText}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                </Grid>
            </Border>
       </Grid>

</ContentView>
