<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:f="clr-namespace:Fonts"
             x:Class="ContaBeeMovil.Views.ResultadosListaView"
             BackgroundColor="{toolkit:AppThemeResource Background}">

    <Grid RowDefinitions="*,Auto">

        <!-- Lista de resultados -->
        <CollectionView x:Name="Lista"
                        Grid.Row="0"
                        BackgroundColor="{toolkit:AppThemeResource Accent1}"/>

        <!-- Overlay de carga -->
        <Grid x:Name="LoadingOverlay"
              Grid.Row="0"
              IsVisible="False"
              BackgroundColor="Transparent"
              InputTransparent="False">
            <ActivityIndicator IsRunning="True"
                               Color="{toolkit:AppThemeResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               WidthRequest="48"
                               HeightRequest="48" />
        </Grid>

        <!-- Barra de paginación -->
        <Grid x:Name="BarraPaginacion"
              Grid.Row="1"
              IsVisible="False"
              Padding="5">

            <Label x:Name="LabelEncontrados"
                   Style="{StaticResource Body2}"
                   HorizontalOptions="Start"
                   VerticalOptions="Center" />

            <HorizontalStackLayout HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   Spacing="5">

                <!-- Botón página anterior -->
                <Border x:Name="BtnAnterior"
                        Style="{StaticResource CircleIconButton}"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAnteriorTapped" />
                    </Border.GestureRecognizers>
                    <Label Text="{x:Static f:FluentUI.chevron_left_20_regular}"
                           Style="{StaticResource CircleIconLabel}" />
                </Border>

                <!-- Página actual -->
                <Label x:Name="LabelPagina"
                       Style="{StaticResource Body2Strong}"
                       FontSize="12"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"
                       MinimumWidthRequest="20" />

                <!-- Botón página siguiente -->
                <Border x:Name="BtnSiguiente"
                        Style="{StaticResource CircleIconButton}"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSiguienteTapped" />
                    </Border.GestureRecognizers>
                    <Label Text="{x:Static f:FluentUI.chevron_right_20_regular}"
                           Style="{StaticResource CircleIconLabel}" />
                </Border>

            </HorizontalStackLayout>

        </Grid>

    </Grid>

</ContentView>
