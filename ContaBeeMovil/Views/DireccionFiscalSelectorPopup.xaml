<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="ContaBeeMovil.Views.DireccionFiscalSelectorPopup"
               CanBeDismissedByTappingOutsideOfPopup="True"
               Background="Transparent" >

    <Border BackgroundColor="{toolkit:AppThemeResource Background}"
            Stroke="Transparent"
            StrokeShape="RoundRectangle 20"
            Padding="20,24"
            WidthRequest="320">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="0.1" />
        </Border.Shadow>

        <VerticalStackLayout Spacing="20">

            <Label Text="Dirección fiscal"
                   HorizontalOptions="Center"
                   FontSize="14"
                   TextColor="{toolkit:AppThemeResource SecondaryText}" />

            <ScrollView MaximumHeightRequest="340">
                <VerticalStackLayout x:Name="PanelLista" Spacing="10" />
            </ScrollView>

        </VerticalStackLayout>
    </Border>

</toolkit:Popup>
