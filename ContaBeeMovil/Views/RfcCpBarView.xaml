<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ContaBeeMovil.Views.RfcCpBarView">

    <Border x:Name="OuterBorder"
            BackgroundColor="Transparent"
            Stroke="Transparent"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 10,10,0,0"
            Padding="1,2">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,-4" Radius="4" Opacity="0.10" />
        </Border.Shadow>

        <Grid x:Name="RootGrid"
              ColumnDefinitions="Auto,*,Auto"
              Padding="10,2,10,2">

            <!-- Botón RFC (izquierda) — abre selector -->
            <Border x:Name="BorderRfc"
                    Grid.Column="0"
                    BackgroundColor="{toolkit:AppThemeResource Tertiary}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 10"
                    Padding="10,6">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,1" Radius="1" Opacity="0.4" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnRfcButtonTapped" />
                </Border.GestureRecognizers>
                <Label x:Name="LabelRfc"
                       Text="?"
                       FontAttributes="Bold"
                       FontSize="13"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       VerticalOptions="Center" />
            </Border>

            <!-- Botón CP (derecha) — abre selector de dirección -->
            <Border x:Name="BorderCp"
                    Grid.Column="2"
                    BackgroundColor="{toolkit:AppThemeResource Tertiary}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 10"
                    Padding="10,6">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,1" Radius="1" Opacity="0.4" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCpButtonTapped" />
                </Border.GestureRecognizers>
                <Label x:Name="LabelCp"
                       Text="?"
                       FontAttributes="Bold"
                       FontSize="13"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       VerticalOptions="Center" />
            </Border>

        </Grid>
    </Border>

</ContentView>
