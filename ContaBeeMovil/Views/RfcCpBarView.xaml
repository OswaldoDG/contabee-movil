<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:f="clr-namespace:Fonts"
             x:Class="ContaBeeMovil.Views.RfcCpBarView">

    <Grid x:Name="RootGrid"
          ColumnDefinitions="Auto,*,Auto"
          BackgroundColor="{toolkit:AppThemeResource Primary}"
          Padding="12,6">

        <Label Grid.Column="0"
               x:Name="IconRfc"
               Text="{x:Static f:FluentUI.person_24_regular}"
               FontFamily="{x:Static f:FluentUI.FontFamily}"
               FontSize="24"
               TextColor="{StaticResource Black}"
               VerticalOptions="Center">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnRfcButtonTapped" />
            </Label.GestureRecognizers>
        </Label>

        <Label Grid.Column="1"
               x:Name="LabelRfcCp"
               Text="? - ?"
               FontSize="13"
               FontAttributes="Bold"
               TextColor="{StaticResource Black}"
               HorizontalOptions="Center"
               VerticalOptions="Center" />

        <Label Grid.Column="2"
               x:Name="IconCp"
               Text="{x:Static f:FluentUI.location_24_regular}"
               FontFamily="{x:Static f:FluentUI.FontFamily}"
               FontSize="24"
               TextColor="{StaticResource Black}"
               VerticalOptions="Center">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCpButtonTapped" />
            </Label.GestureRecognizers>
        </Label>

    </Grid>

</ContentView>
