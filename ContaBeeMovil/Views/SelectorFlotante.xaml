<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:f="clr-namespace:Fonts"
             x:Class="ContaBeeMovil.Views.SelectorFlotante">

    <Border x:Name="Trigger"
            BackgroundColor="{toolkit:AppThemeResource Background}"
            StrokeShape="RoundRectangle 12"
            StrokeThickness="1"
            Stroke="{toolkit:AppThemeResource Accent1}"
            Padding="5,0"
            HeightRequest="40">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTriggerTapped" />
        </Border.GestureRecognizers>
        <Grid ColumnDefinitions="*,Auto">
            <Label x:Name="LabelTexto"
                   VerticalOptions="Center"
                   FontSize="14"
                   TextColor="{toolkit:AppThemeResource SecondaryText}"
                   LineBreakMode="TailTruncation" />
            <Label Grid.Column="1"
                   Text="{x:Static f:FluentUI.chevron_down_20_regular}"
                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                   FontSize="16"
                   TextColor="{toolkit:AppThemeResource SecondaryText}"
                   VerticalOptions="Center"
                   Margin="1,0,0,0" />
        </Grid>
    </Border>

</ContentView>
