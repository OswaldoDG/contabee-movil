<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ContaBeeMovil.Pages.Registro.PaginaRegistro"
             BackgroundColor="{toolkit:AppThemeResource Background}"
             NavigationPage.HasNavigationBar="False"
             Title="Registro"
             Shell.TabBarIsVisible="False">
    <Grid>
        <ScrollView>
        <Grid RowDefinitions="Auto,Auto"
              Padding="20,0,20,0">

            <!-- Header -->
            <VerticalStackLayout Grid.Row="0"
                                 Spacing="0"
                                 Padding="0,0,0,20">
                <Label Text="Crear una cuenta"
                       FontSize="25"
                       FontAttributes="Bold"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       HorizontalOptions="Start"/>
                <Label Text="Complete la información."
                       FontSize="12"
                       TextColor="{toolkit:AppThemeResource SecondaryText}"
                       HorizontalOptions="Start"/>
            </VerticalStackLayout>

            <!-- Form -->
            <VerticalStackLayout Grid.Row="1"
                                 Spacing="6"
                                 VerticalOptions="Start">

                <!-- Aviso de privacidad y Términos del servicio -->
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="2"
                      Margin="2,0,0,0">
                    <CheckBox x:Name="ChkPrivacidad"
                              Grid.Column="0"
                              IsChecked="{Binding AceptaPrivacidad}"
                              Color="{toolkit:AppThemeResource Primary}"
                              VerticalOptions="Center"/>
                    <FlexLayout Grid.Column="1"
                                Wrap="Wrap"
                                AlignItems="Center">
                        <Label Text="He leído y acepto el "
                               TextColor="{toolkit:AppThemeResource PrimaryText}"
                               FontSize="12"/>
                        <Label Text="aviso de privacidad"
                               TextColor="{toolkit:AppThemeResource Primary}"
                               FontAttributes="Bold"
                               TextDecorations="Underline"
                               FontSize="12">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAvisoPrivacidadTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                        <Label Text=" y los "
                               TextColor="{toolkit:AppThemeResource PrimaryText}"
                               FontSize="12"/>
                        <Label Text="términos del servicio"
                               TextColor="{toolkit:AppThemeResource Primary}"
                               FontAttributes="Bold"
                               TextDecorations="Underline"
                               FontSize="12">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTerminosTapped"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </FlexLayout>
                </Grid>

                <!-- Cupón (siempre visible, en la parte superior) -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        BackgroundColor="{toolkit:AppThemeResource Alternate}"
                        Padding="12,8">
                    <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="8">
                        <Entry x:Name="CuponEntry"
                               Grid.Column="0"
                               Placeholder="Cupón de bienvenida (opcional)"
                               Text="{Binding CuponRegistro}"
                               Keyboard="Plain"
                               BackgroundColor="Transparent"
                               PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                               FontSize="15"/>
                        <Image Grid.Column="1"
                               Source="{AppThemeBinding Light=cupon_claro.png, Dark=cupon_oscuro.png}"
                               WidthRequest="24"
                               HeightRequest="24"
                               Aspect="AspectFit"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Campos del formulario -->
                <VerticalStackLayout x:Name="PanelCampos"
                                     Spacing="8">

                    <!-- Nombre -->
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="Transparent"
                            BackgroundColor="{toolkit:AppThemeResource Alternate}"
                            Padding="12,8">
                        <Entry Placeholder="Nombre"
                               Text="{Binding Nombre}"
                               Keyboard="Chat"
                               BackgroundColor="Transparent"
                               PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                               FontSize="15"
                               ClearButtonVisibility="WhileEditing"/>
                    </Border>

                    <!-- Correo -->
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="Transparent"
                            BackgroundColor="{toolkit:AppThemeResource Alternate}"
                            Padding="12,8">
                        <Entry Placeholder="Correo Electrónico"
                               Text="{Binding Email}"
                               Keyboard="Email"
                               BackgroundColor="Transparent"
                               PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                               FontSize="15"/>
                    </Border>

                    <!-- Contraseña -->
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="Transparent"
                            BackgroundColor="{toolkit:AppThemeResource Alternate}"
                            Padding="12,8">
                        <Entry x:Name="PasswordEntry"
                               Placeholder="Contraseña"
                               Text="{Binding Password}"
                               IsPassword="True"
                               Keyboard="Plain"
                               BackgroundColor="Transparent"
                               PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                               FontSize="15"/>
                    </Border>

                    <!-- Confirmar Contraseña -->
                    <Border StrokeShape="RoundRectangle 10"
                            Stroke="Transparent"
                            BackgroundColor="{toolkit:AppThemeResource Alternate}"
                            Padding="0">
                        <Grid ColumnDefinitions="*,Auto"
                                Padding="12,10">
                            <Entry x:Name="ConfirmPasswordEntry"
                                   Grid.Column="0"
                                   Placeholder="Confirmar Contraseña"
                                   Text="{Binding ConfirmarPassword}"
                                   IsPassword="True"
                                   Keyboard="Plain"
                                   BackgroundColor="Transparent"
                                   PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                                   FontSize="15"
                                   TextChanged="OnConfirmarPasswordTextChanged"/>
                            <mi:MauiIcon x:Name="ToggleConfirmPasswordButton"
                                         Grid.Column="1"
                                         Icon="{mi:Material Icon=Visibility}"
                                         IconColor="{toolkit:AppThemeResource Icon}"
                                         IconSize="22"
                                         VerticalOptions="Center"
                                         BackgroundColor="Transparent">
                                <mi:MauiIcon.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnToggleConfirmPasswordClicked"/>
                                </mi:MauiIcon.GestureRecognizers>
                            </mi:MauiIcon>
                        </Grid>
                    </Border>

                    <!-- Error: contraseñas no coinciden -->
                    <Label x:Name="ErrorCoincidenciaLabel"
                           Text="Las contraseñas no coinciden"
                           TextColor="{toolkit:AppThemeResource Error}"
                           FontSize="12"
                           Margin="4,0,0,0"
                           IsVisible="False"/>

                    <!-- Password requirements -->
                    <VerticalStackLayout Spacing="2"
                            Margin="8,0,0,0">
                        <Label Text="Tu contraseña debe contener:"
                               TextColor="{toolkit:AppThemeResource SecondaryText}"
                               FontSize="12"
                               FontAttributes="Bold"
                               Margin="0,0,0,1"/>
                        <VerticalStackLayout Spacing="2"
                                Margin="10,0,0,0">
                            <HorizontalStackLayout Spacing="8"
                                    VerticalOptions="Center">
                                <mi:MauiIcon x:Name="IconMin6"
                                             Icon="{mi:Material Icon=Check}"
                                             IconColor="{toolkit:AppThemeResource Disabled}"
                                             IconSize="16"
                                             WidthRequest="16"
                                        HeightRequest="16"/>
                                <Label Text="Mínimo 6 caracteres"
                                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                                       FontSize="12"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8"
                                    VerticalOptions="Center">
                                <mi:MauiIcon x:Name="IconMayus"
                                             Icon="{mi:Material Icon=Check}"
                                             IconColor="{toolkit:AppThemeResource Disabled}"
                                             IconSize="16"
                                             WidthRequest="16"
                                        HeightRequest="16"/>
                                <Label Text="Una letra mayúscula"
                                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                                       FontSize="12"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8"
                                    VerticalOptions="Center">
                                <mi:MauiIcon x:Name="IconNumero"
                                             Icon="{mi:Material Icon=Check}"
                                             IconColor="{toolkit:AppThemeResource Disabled}"
                                             IconSize="16"
                                             WidthRequest="16"
                                        HeightRequest="16"/>
                                <Label Text="Un número"
                                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                                       FontSize="12"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="8"
                                    VerticalOptions="Center">
                                <mi:MauiIcon x:Name="IconEspecial"
                                             Icon="{mi:Material Icon=Check}"
                                             IconColor="{toolkit:AppThemeResource Disabled}"
                                             IconSize="16"
                                             WidthRequest="16"
                                        HeightRequest="16"/>
                                <Label Text="Caracter especial (@ $ % &amp; . _ # )"
                                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                                       FontSize="12"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>

                <!-- Crear cuenta button -->
                <Button x:Name="BtnCrearCuenta"
                        Text="Crear cuenta"
                        Command="{Binding RegistrarCommand}"
                        TextColor="{toolkit:AppThemeResource PrimaryText}"
                        FontAttributes="Bold"
                        HeightRequest="44"
                        CornerRadius="10"
                        HorizontalOptions="Center"
                        WidthRequest="220"
                        Margin="0,10,0,0"/>

                <!-- Link para iniciar sesión -->
                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="6"
                                       Padding="0,4,0,10">
                    <Label Text="¿Ya tiene una cuenta?"
                           TextColor="{toolkit:AppThemeResource PrimaryText}"
                           VerticalOptions="Center"
                           FontSize="13"/>
                    <Label Text="Iniciar sesión"
                           TextColor="{toolkit:AppThemeResource Primary}"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           FontSize="13">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IrALoginCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>

        </Grid>
        </ScrollView>

        <!-- Spinner overlay -->
        <Grid IsVisible="{Binding EstaCargando}"
              BackgroundColor="#80000000">
            <ActivityIndicator IsRunning="{Binding EstaCargando}"
                               Color="{toolkit:AppThemeResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               WidthRequest="48"
                               HeightRequest="48"/>
        </Grid>

    </Grid>
</ContentPage>
