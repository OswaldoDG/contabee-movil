<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ContaBeeMovil.Pages.Registro.PaginaRegistro"
             BackgroundColor="{toolkit:AppThemeResource Background}"
             Title="Registro">
    <Grid>
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">

            <!-- Header -->
            <Label Text="Crear una cuenta"
                   FontSize="34"
                   FontAttributes="Bold"
                   TextColor="{toolkit:AppThemeResource PrimaryText}"
                   HorizontalOptions="Start"
                   Margin="0,8,0,0"/>
            <Label Text="Complete la información."
                   FontSize="14"
                   TextColor="{toolkit:AppThemeResource SecondaryText}"
                   HorizontalOptions="Start"
                   Margin="0,0,0,8"/>

            <!-- Nombre -->
                <Border StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    BackgroundColor="{toolkit:AppThemeResource Alternate}"
                    Padding="14"
                    Margin="0,6,0,0">
                <Entry Placeholder="Nombre"
                       Text="{Binding Nombre}"
                       BackgroundColor="Transparent"
                       PlaceholderColor="{toolkit:AppThemeResource SecondaryText }"
                       FontSize="16"
                       ClearButtonVisibility="WhileEditing"/>
            </Border>

            <!-- Correo -->
                <Border StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    BackgroundColor="{toolkit:AppThemeResource Alternate}"
                    Padding="14"
                    Margin="0,6,0,0">
                <Entry Placeholder="Correo Electronico"
                       Text="{Binding Email}"
                       Keyboard="Email"
                       BackgroundColor="Transparent"
                       PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                       FontSize="16"/>
            </Border>

            <!-- Contraseña -->
                <Border StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    BackgroundColor="{toolkit:AppThemeResource Alternate}"
                    Padding="0"
                    Margin="0,6,0,0">
                <Grid ColumnDefinitions="*,Auto" Padding="14">
                    <Entry x:Name="PasswordEntry"
                           Grid.Column="0"
                           Placeholder="Contraseña"
                           Text="{Binding Password}"
                           IsPassword="True"
                           BackgroundColor="Transparent"
                           PlaceholderColor="{toolkit:AppThemeResource  SecondaryText}"
                           FontSize="16"
                            
                           />
                    <mi:MauiIcon x:Name="TogglePasswordButton"
             Grid.Column="1"
             Icon="{mi:Material Icon=Visibility}"
             IconColor="{toolkit:AppThemeResource Icon}"
             IconSize="25"
             VerticalOptions="Center"
             BackgroundColor="Transparent">
                        <mi:MauiIcon.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTogglePasswordClicked"/>
                        </mi:MauiIcon.GestureRecognizers>
                    </mi:MauiIcon>
                </Grid>
            </Border>

            <!-- Confirmar Contraseña -->
                <Border StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    BackgroundColor="{toolkit:AppThemeResource Alternate}"
                    Padding="0"
                    Margin="0,6,0,0">
                <Grid ColumnDefinitions="*,Auto" Padding="14">
                    <Entry x:Name="ConfirmPasswordEntry"
                           Grid.Column="0"
                           Placeholder="Confirmar Contraseña"
                           Text="{Binding ConfirmarPassword}"
                           IsPassword="True"
                           BackgroundColor="Transparent"
                           PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                           FontSize="16"/>
                    <mi:MauiIcon x:Name="ToggleConfirmPasswordButton"
             Grid.Column="1"
             Icon="{mi:Material Icon=Visibility}"
             IconColor="{toolkit:AppThemeResource Icon}"
             IconSize="25"
             VerticalOptions="Center"
             BackgroundColor="Transparent">
                        <mi:MauiIcon.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnToggleConfirmPasswordClicked"/>
                        </mi:MauiIcon.GestureRecognizers>
                    </mi:MauiIcon>
                </Grid>
            </Border>

            <!-- Password requirements (FontAwesome icons) -->
            <VerticalStackLayout Spacing="5" Margin="6,5,0,0">
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <mi:MauiIcon x:Name="IconMin6" 
                                 Icon="{mi:Material Icon=Check}"
                                 IconColor="{toolkit:AppThemeResource Disabled}"
                                 IconSize="20"
                                 WidthRequest="20" HeightRequest="20"/>
                    <Label Text="Mínimo 6 caracteres"
                           TextColor="{toolkit:AppThemeResource PrimaryText}"
                           FontSize="14"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <mi:MauiIcon x:Name="IconMayus"
                                 Icon="{mi:Material Icon=Check}"
                                 IconColor="{toolkit:AppThemeResource Disabled}"
                                 IconSize="20"
                                 WidthRequest="20" HeightRequest="20"/>
                    <Label Text="Una letra mayúscula"
                           TextColor="{toolkit:AppThemeResource PrimaryText}"
                           FontSize="14"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <mi:MauiIcon x:Name="IconNumero"
                                 Icon="{mi:Material Icon=Check}"
                                 IconColor="{toolkit:AppThemeResource Disabled}"
                                 IconSize="20"
                                 WidthRequest="18" HeightRequest="18"/>
                    <Label Text="Un número"
                           TextColor="{toolkit:AppThemeResource PrimaryText}"
                           FontSize="14"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <mi:MauiIcon x:Name="IconEspecial"
                                 Icon="{mi:Material Icon=Check}"
                                 IconColor="{toolkit:AppThemeResource Disabled}"
                                 IconSize="20"
                                 WidthRequest="18" HeightRequest="18"/>
                    <Label Text="Caracter especial (@ $ % &amp; . _ # )"
                           TextColor="{toolkit:AppThemeResource PrimaryText}"
                           FontSize="14"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Crear cuenta button -->
            <Button Text="Crear cuenta"
                    Command="{Binding RegistrarCommand}"
                    BackgroundColor="{toolkit:AppThemeResource Primary}"
                    TextColor="{toolkit:AppThemeResource PrimaryText}"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    CornerRadius="10"
                    HorizontalOptions="Center"
                    WidthRequest="220"
                    Margin="0,18,0,6"
                    />

            <!-- Link para iniciar sesión -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="6" Margin="0,6,0,24">
                <Label Text="¿Ya tiene una cuenta?"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       VerticalOptions="Center"
                       FontSize="14"/>
                <Label Text="Iniciar sesión"
                       TextColor="{toolkit:AppThemeResource Primary}"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       FontSize="14">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrALoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

    <!-- Spinner overlay -->
    <Grid IsVisible="{Binding EstaCargando}"
          BackgroundColor="#80000000">
        <ActivityIndicator IsRunning="{Binding EstaCargando}"
                           Color="{toolkit:AppThemeResource Primary}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           WidthRequest="48"
                           HeightRequest="48"/>
    </Grid>

    </Grid>
</ContentPage>
