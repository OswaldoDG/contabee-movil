<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="ContaBee.Pages.Cupones.PaginaCupones"
    Title="Cupones"
    BackgroundColor="{toolkit:AppThemeResource Background}">

    <Grid RowDefinitions="Auto,1,*,Auto" Padding="0">
        <Grid x:Name="BusquedaSection"
              Grid.Row="0"
              BackgroundColor="{toolkit:AppThemeResource AppBarPrimary}"
              Padding="16,10,16,12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Border StrokeThickness="1"
                        Stroke="{toolkit:AppThemeResource Accent1}"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="{toolkit:AppThemeResource Background}"
                        HeightRequest="56"
                        VerticalOptions="Center"
                        Padding="14,8">
                    <Entry Placeholder="Código"
                           Text="{Binding CodigoCupon}"
                           ReturnType="Search"
                           PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                           TextColor="{toolkit:AppThemeResource PrimaryText}"
                           BackgroundColor="Transparent" />
                </Border>

                <Button Grid.Column="1"
                        Text="Buscar"
                        Command="{Binding BuscarCuponCommand}"
                        WidthRequest="120"
                        HeightRequest="56"
                        Padding="0"
                        CornerRadius="12"
                        BackgroundColor="{toolkit:AppThemeResource Primary}"
                        TextColor="{StaticResource Black}"
                        FontAttributes="Bold"
                        VerticalOptions="Center" />
            </Grid>
        </Grid>

        <BoxView Grid.Row="1"
                 HeightRequest="1"
                 Color="{toolkit:AppThemeResource Accent1}" />

        <CollectionView Grid.Row="2"
                        Margin="16,12,16,16"
                        ItemsSource="{Binding Cupones}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="8" Padding="20">
                    <Label Text="No hay cupones disponibles"
                           HorizontalOptions="Center"
                           FontSize="16"
                           TextColor="{toolkit:AppThemeResource SecondaryText}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1.5"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{toolkit:AppThemeResource CardBackground}"
                            Margin="0,0,0,12"
                            Padding="14"
                            HeightRequest="128">

                        <Border.Shadow>
                            <Shadow Brush="#000000"
                                    Offset="0,4"
                                    Radius="8"
                                    Opacity="0.15" />
                        </Border.Shadow>

                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="*,*"
                              ColumnSpacing="12"
                              RowSpacing="6">
                            <Label Grid.Row="0"
                                   Grid.Column="0"
                                   Text="{Binding Nombre}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2"
                                   VerticalTextAlignment="End"
                                   TextColor="{toolkit:AppThemeResource PrimaryText}"/>

                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Text="{Binding Descripcion, TargetNullValue='Sin descripción'}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2"
                                   VerticalTextAlignment="Start"
                                   TextColor="{toolkit:AppThemeResource SecondaryText}"/>

                            <Grid Grid.Column="1"
                                  Grid.RowSpan="2"
                                  WidthRequest="136"
                                  HeightRequest="78"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center">
                                <Button Text="Aplicar"
                                        BackgroundColor="{toolkit:AppThemeResource Primary}"
                                        TextColor="{StaticResource Black}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AplicarCuponCommand}"
                                        CommandParameter="{Binding .}"
                                        Padding="0"
                                        CornerRadius="12"
                                        FontAttributes="Bold"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding Aplicado}"
                                                     Value="True">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>

                                <Border IsVisible="{Binding Aplicado}"
                                        StrokeThickness="1"
                                        Stroke="{toolkit:AppThemeResource Accent1}"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{toolkit:AppThemeResource SecondaryBackground}"
                                        Padding="10,8"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill">
                                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="{Binding Fecha, StringFormat='{0:dd/MM/yy}'}"
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               TextColor="{toolkit:AppThemeResource PrimaryText}" />
                                        <Label Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TextoCuentaFiscalAplicacion}"
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{toolkit:AppThemeResource PrimaryText}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="4"
              IsVisible="{Binding EstaCargando}"
              BackgroundColor="{toolkit:AppThemeResource Shadow}"
              InputTransparent="False">
            <ActivityIndicator IsRunning="{Binding EstaCargando}"
                               Color="{toolkit:AppThemeResource Primary}"
                               WidthRequest="48"
                               HeightRequest="48"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>