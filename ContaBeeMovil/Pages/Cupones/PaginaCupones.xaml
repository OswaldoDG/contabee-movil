<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="ContaBee.Pages.Cupones.PaginaCupones"
    Title="Cupones"
    BackgroundColor="{toolkit:AppThemeResource Background}">

    <Grid RowDefinitions="Auto,1,*,Auto" Padding="0">
        <Grid x:Name="BusquedaSection"
              Grid.Row="0"
              BackgroundColor="{toolkit:AppThemeResource AppBarPrimary}"
              Padding="16,10,16,12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Border StrokeThickness="1"
                        Stroke="{toolkit:AppThemeResource Accent1}"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="{toolkit:AppThemeResource Background}"
                        HeightRequest="56"
                        VerticalOptions="Center"
                        Padding="14,8">
                    <Entry Placeholder="Código"
                           Text="{Binding CodigoCupon}"
                           ReturnType="Search"
                           PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                           TextColor="{toolkit:AppThemeResource PrimaryText}"
                           BackgroundColor="Transparent" />
                </Border>

                <Button Grid.Column="1"
                        Text="Buscar"
                        Command="{Binding BuscarCuponCommand}"
                        WidthRequest="120"
                        HeightRequest="56"
                        Padding="0"
                        CornerRadius="12"
                        BackgroundColor="{toolkit:AppThemeResource Primary}"
                        TextColor="{StaticResource Black}"
                        FontAttributes="Bold"
                        VerticalOptions="Center" />
            </Grid>
        </Grid>

        <BoxView Grid.Row="1"
                 HeightRequest="1"
                 Color="{toolkit:AppThemeResource Accent1}" />

        <CollectionView Grid.Row="2"
                        Margin="16,12,16,16"
                        ItemsSource="{Binding Cupones}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout Spacing="8" Padding="20">
                    <Label Text="No hay cupones disponibles"
                           HorizontalOptions="Center"
                           FontSize="16"
                           TextColor="{toolkit:AppThemeResource SecondaryText}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1.5"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="{toolkit:AppThemeResource CardBackground}"
                            Margin="0,0,0,12"
                            Padding="16">

                        <Border.Shadow>
                            <Shadow Brush="#000000"
                                    Offset="0,4"
                                    Radius="8"
                                    Opacity="0.15" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="6">

                            <Label Text="{Binding Nombre}"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2"
                                   TextColor="{toolkit:AppThemeResource PrimaryText}" />

                            <Label Text="{Binding Descripcion, TargetNullValue='Sin descripción'}"
                                   FontSize="14"
                                   LineBreakMode="WordWrap"
                                   MaxLines="3"
                                   TextColor="{toolkit:AppThemeResource SecondaryText}" />

                            <Button Text="Aplicar"
                                    BackgroundColor="{toolkit:AppThemeResource Primary}"
                                    TextColor="{StaticResource Black}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AplicarCuponCommand}"
                                    CommandParameter="{Binding .}"
                                    Padding="20,0,20,0"
                                    HeightRequest="48"
                                    CornerRadius="10"
                                    FontAttributes="Bold"
                                    HorizontalOptions="Center"
                                    Margin="0,4,0,0">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button"
                                                 Binding="{Binding Aplicado}"
                                                 Value="True">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>

                            <Border IsVisible="{Binding Aplicado}"
                                    StrokeThickness="1"
                                    Stroke="{toolkit:AppThemeResource Accent1}"
                                    StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{toolkit:AppThemeResource SecondaryBackground}"
                                    Padding="16,5"
                                    HorizontalOptions="Center"
                                    Margin="0,4,0,0">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Label Grid.Column="0"
                                           Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TextoCuentaFiscalAplicacion}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1"
                                           FontAttributes="Bold"
                                           VerticalTextAlignment="Center"
                                           TextColor="{toolkit:AppThemeResource PrimaryText}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Fecha, StringFormat='{0:dd/MM/yy}'}"
                                           FontAttributes="Bold"
                                           VerticalTextAlignment="Center"
                                           TextColor="{toolkit:AppThemeResource SecondaryText}" />
                                </Grid>
                            </Border>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="4"
              IsVisible="{Binding EstaCargando}"
              BackgroundColor="{toolkit:AppThemeResource Shadow}"
              InputTransparent="False">
            <ActivityIndicator IsRunning="{Binding EstaCargando}"
                               Color="{toolkit:AppThemeResource Primary}"
                               WidthRequest="48"
                               HeightRequest="48"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>