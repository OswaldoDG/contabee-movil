<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             xmlns:pageModel="clr-namespace:ContaBeeMovil.PageModels"
             xmlns:models="clr-namespace:ContaBeeMovil.Models"
             x:DataType="pageModel:TaskDetailPageModel"
             x:Class="ContaBeeMovil.Pages.TaskDetailPage"
             Title="Task">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Text="Delete"
            Command="{Binding DeleteCommand}"
            Order="Primary"
            Priority="0"
            IconImageSource="{StaticResource IconDelete}"
            SemanticProperties.Description="Delete Task" />
    </ContentPage.ToolbarItems>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="12" Padding="{StaticResource LayoutPadding}">

                <Label Text="TASK DETAILS" Style="{StaticResource SectionHeader}"/>

                <Border Style="{StaticResource FormCard}">
                    <VerticalStackLayout Spacing="6">
                        <sf:SfTextInputLayout Hint="Task">
                            <Entry
                                Text="{Binding Title}"
                                SemanticProperties.Description="Task" />
                        </sf:SfTextInputLayout>

                        <!-- Completed as a row inside the card -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="4,8">
                            <Label Text="Completed"
                                   Style="{StaticResource Body1}"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource SecondaryText}, Dark={StaticResource SecondaryTextDark}}"/>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding IsCompleted}"
                                      SemanticProperties.Description="Completed"
                                      SemanticProperties.Hint="Indicates if this task is completed" />
                        </Grid>

                        <BoxView Style="{StaticResource Divider}"/>

                        <sf:SfTextInputLayout
                            IsVisible="{Binding IsExistingProject}"
                            SemanticProperties.Description="ComboBox to select Project"
                            SemanticProperties.Hint="State Collapsed"
                            Hint="Project">
                            <Picker
                                ItemsSource="{Binding Projects}"
                                ItemDisplayBinding="{Binding Name, x:DataType=models:Project}"
                                SelectedItem="{Binding Project}"
                                SelectedIndex="{Binding SelectedProjectIndex}"
                                SemanticProperties.Description="Project State Expanded"
                                SemanticProperties.Hint="Which project this task belongs to"/>
                        </sf:SfTextInputLayout>
                    </VerticalStackLayout>
                </Border>

                <Button
                    Text="Save"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
