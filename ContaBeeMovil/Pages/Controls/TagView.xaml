<?xml version="1.0" encoding="utf-8" ?>
<Border xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        x:Class="ContaBeeMovil.Pages.Controls.TagView"
        xmlns:models="clr-namespace:ContaBeeMovil.Models"
        StrokeShape="RoundRectangle 10"
        HeightRequest="28"
        StrokeThickness="0"
        Background="{Binding DisplayColor}"
        Padding="{OnPlatform '10,0,10,6',Android='10,0,10,0'}"
        Margin="0,0,4,4"
        x:DataType="models:Tag">

        <Label Text="{Binding Title}" x:Name="TitleLabel"
            TextColor="{AppThemeBinding Light={StaticResource LightBackground},Dark={StaticResource DarkBackground}}"
            FontSize="12"
            VerticalOptions="Center"
            VerticalTextAlignment="Center"/>
</Border>