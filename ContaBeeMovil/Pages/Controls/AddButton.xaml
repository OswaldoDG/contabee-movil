<?xml version="1.0" encoding="utf-8" ?>
<Button xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ContaBeeMovil.Pages.Controls.AddButton"
    ImageSource="{StaticResource IconAdd}"
    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
    CornerRadius="28"
    HeightRequest="56"
    WidthRequest="56"
    VerticalOptions="End"
    HorizontalOptions="End"
    Margin="24"
    Shadow="{Shadow Brush={AppThemeBinding Light={StaticResource ShadowPrimary}, Dark={StaticResource ShadowPrimaryDark}}, Offset='0,4', Radius=12, Opacity=0.4}"
    SemanticProperties.Description="Add" />
