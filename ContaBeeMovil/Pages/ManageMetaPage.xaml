<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ContaBeeMovil.PageModels"
             xmlns:models="clr-namespace:ContaBeeMovil.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="pageModels:ManageMetaPageModel"
             x:Class="ContaBeeMovil.Pages.ManageMetaPage"
             x:Name="MetaPage"
             Title="Categories and Tags">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
                BindingContext="{Binding Path=BindingContext, Source={x:Reference MetaPage}, x:DataType=ContentPage}"
                EventName="Appearing"
                Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>
    <ContentPage.Resources>
        <Style x:Key="InvalidEntryStyle" TargetType="Entry">
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource ErrorDark}}" />
        </Style>

        <Style TargetType="Entry">
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource DarkOnLightBackground}, Dark={StaticResource LightOnDarkBackground}}" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="FontFamily" Value="OpenSansRegular"/>
            <Setter Property="FontSize" Value="{OnIdiom 15,Desktop=20}" />
            <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray500}}" />
            <Setter Property="MinimumHeightRequest" Value="44"/>
            <Setter Property="MinimumWidthRequest" Value="44"/>
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Reset App" Command="{Binding ResetCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="{StaticResource LayoutPadding}">

            <!-- Categories Section -->
            <Label Text="CATEGORIES" Style="{StaticResource SectionHeader}"/>

            <VerticalStackLayout Spacing="8"
                BindableLayout.ItemsSource="{Binding Categories}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:Category">
                        <Border Style="{StaticResource FormCard}" Padding="12,10">
                            <Grid ColumnSpacing="10" ColumnDefinitions="*,Auto,36,Auto"
                                  VerticalOptions="Center">
                                <Entry Text="{Binding Title}"
                                       Placeholder="Category name"
                                       SemanticProperties.Description="{Binding Title}"
                                       Grid.Column="0"
                                       VerticalOptions="Center" />
                                <Entry Text="{Binding Color}"
                                       Placeholder="#HEX"
                                       Grid.Column="1"
                                       WidthRequest="90"
                                       x:Name="ColorEntry"
                                       VerticalOptions="Center"
                                       SemanticProperties.Description="{Binding Title, StringFormat='{}{0} Color'}"
                                       SemanticProperties.Hint="Category color in HEX format">
                                    <Entry.Behaviors>
                                        <toolkit:TextValidationBehavior
                                            InvalidStyle="{StaticResource InvalidEntryStyle}"
                                            Flags="ValidateOnUnfocused"
                                            RegexPattern="^#(?:[0-9a-fA-F]{3}){1,2}$" />
                                    </Entry.Behaviors>
                                </Entry>

                                <Border Grid.Column="2"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0"
                                        HeightRequest="32"
                                        WidthRequest="32"
                                        VerticalOptions="Center"
                                        BackgroundColor="{Binding Text, Source={x:Reference ColorEntry}, x:DataType=Entry}"
                                        SemanticProperties.HeadingLevel="None" />

                                <ImageButton Grid.Column="3"
                                             Source="{StaticResource IconDelete}"
                                             Background="Transparent"
                                             HeightRequest="40"
                                             WidthRequest="40"
                                             VerticalOptions="Center"
                                             Command="{Binding DeleteCategoryCommand, Source={RelativeSource AncestorType={x:Type pageModels:ManageMetaPageModel}}, x:DataType=pageModels:ManageMetaPageModel}"
                                             CommandParameter="{Binding .}"
                                             SemanticProperties.Description="{Binding Title, StringFormat='Delete {0} Category'}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Grid ColumnSpacing="10" ColumnDefinitions="*,Auto" Margin="0,4">
                <Button Text="Save Categories"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCategoriesCommand}"
                        SemanticProperties.Description="Save Categories"
                        Grid.Column="0" />

                <Button ImageSource="{StaticResource IconAdd}"
                        Style="{StaticResource SecondaryButton}"
                        HeightRequest="52"
                        WidthRequest="52"
                        Padding="0"
                        Command="{Binding AddCategoryCommand}"
                        Grid.Column="1"
                        SemanticProperties.Description="Add Categories" />
            </Grid>

            <!-- Divider between sections -->
            <BoxView Style="{StaticResource Divider}" Margin="0,8"/>

            <!-- Tags Section -->
            <Label Text="TAGS" Style="{StaticResource SectionHeader}"/>

            <VerticalStackLayout Spacing="8"
                BindableLayout.ItemsSource="{Binding Tags}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:Tag">
                        <Border Style="{StaticResource FormCard}" Padding="12,10">
                            <Grid ColumnSpacing="10" ColumnDefinitions="*,Auto,36,Auto"
                                  VerticalOptions="Center">
                                <Entry Text="{Binding Title}"
                                       Placeholder="Tag name"
                                       Grid.Column="0"
                                       VerticalOptions="Center"
                                       SemanticProperties.Description="{Binding Title}" />
                                <Entry Text="{Binding Color}"
                                       Placeholder="#HEX"
                                       Grid.Column="1"
                                       WidthRequest="90"
                                       x:Name="ColorEntry"
                                       VerticalOptions="Center"
                                       SemanticProperties.Description="{Binding Title, StringFormat='{}{0} Color'}"
                                       SemanticProperties.Hint="Tag color in HEX format">
                                    <Entry.Behaviors>
                                        <toolkit:TextValidationBehavior
                                            InvalidStyle="{StaticResource InvalidEntryStyle}"
                                            Flags="ValidateOnUnfocused"
                                            RegexPattern="^#(?:[0-9a-fA-F]{3}){1,2}$" />
                                    </Entry.Behaviors>
                                </Entry>

                                <Border Grid.Column="2"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0"
                                        HeightRequest="32"
                                        WidthRequest="32"
                                        VerticalOptions="Center"
                                        BackgroundColor="{Binding Text, Source={x:Reference ColorEntry}, x:DataType=Entry}"
                                        SemanticProperties.HeadingLevel="None" />

                                <ImageButton Grid.Column="3"
                                             Source="{StaticResource IconDelete}"
                                             Background="Transparent"
                                             HeightRequest="40"
                                             WidthRequest="40"
                                             VerticalOptions="Center"
                                             Command="{Binding DeleteTagCommand, Source={RelativeSource AncestorType={x:Type pageModels:ManageMetaPageModel}}, x:DataType=pageModels:ManageMetaPageModel}"
                                             CommandParameter="{Binding .}"
                                             SemanticProperties.Description="{Binding Title, StringFormat='Delete {0} Tag'}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Grid ColumnSpacing="10" ColumnDefinitions="*,Auto" Margin="0,4,0,20">
                <Button Text="Save Tags"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveTagsCommand}"
                        SemanticProperties.Description="Save Tags"
                        Grid.Column="0" />

                <Button ImageSource="{StaticResource IconAdd}"
                        Style="{StaticResource SecondaryButton}"
                        HeightRequest="52"
                        WidthRequest="52"
                        Padding="0"
                        Command="{Binding AddTagCommand}"
                        Grid.Column="1"
                        SemanticProperties.Description="Add Tags" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
