<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ContaBeeMovil.Pages.Perfil.RFCsPage"
             Title="Mis Cuentas Fiscales"
             BackgroundColor="{toolkit:AppThemeResource Background}"
             Shell.BackgroundColor="{toolkit:AppThemeResource AppBarPrimary}"
             Shell.TitleColor="{toolkit:AppThemeResource PrimaryText}"
             Shell.ForegroundColor="{toolkit:AppThemeResource PrimaryText}"
             Shell.TabBarIsVisible="False">

    <Grid>
        <CollectionView x:Name="ListaCuentas" Margin="12,8">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView Margin="0,6">
                        <SwipeView.LeftItems>
                            <SwipeItems Mode="Execute" SwipeBehaviorOnInvoked="Close">
                                <SwipeItem BackgroundColor="{toolkit:AppThemeResource Error}"
                                           Command="{Binding DeleteCommand}"
                                           mi:MauiIcon.Value="{mi:Material Icon=Delete}" />
                            </SwipeItems>
                        </SwipeView.LeftItems>

                        <Border Padding="16,14"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{toolkit:AppThemeResource Accent1}"
                                StrokeThickness="1"
                                BackgroundColor="{toolkit:AppThemeResource SecondaryBackground}">
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                    <Label Text="{Binding Rfc}"
                                           FontAttributes="Bold"
                                           FontSize="18"
                                           TextColor="{toolkit:AppThemeResource PrimaryText}" />
                                    <Label Text="{Binding Regimen}"
                                           FontSize="13"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{toolkit:AppThemeResource SecondaryText}" />
                                </VerticalStackLayout>

                                <!-- <Border Grid.Column="1"
                                        WidthRequest="48"
                                        HeightRequest="48"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0"
                                        BackgroundColor="{toolkit:AppThemeResource Primary}"
                                        VerticalOptions="Center">
                                    <mi:MauiIcon Icon="{mi:Material Icon=ContactPage}"
                                                 IconSize="26"
                                                 IconColor="{toolkit:AppThemeResource PrimaryText}"
                                                 HorizontalOptions="Center"
                                                 VerticalOptions="Center" />
                                </Border> -->
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Overlay de carga -->
        <Grid x:Name="LoadingOverlay"
              IsVisible="False"
              BackgroundColor="{toolkit:AppThemeResource Shadow}"
              InputTransparent="False">
            <ActivityIndicator IsRunning="True"
                               Color="{toolkit:AppThemeResource Primary}"
                               WidthRequest="48"
                               HeightRequest="48"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>

        <!-- FAB agregar -->
        <Button x:Name="BtnAgregar"
                Text="+"
                FontSize="30"
                FontAttributes="Bold"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="16"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,16,28"
                BackgroundColor="{toolkit:AppThemeResource Primary}"
                TextColor="{toolkit:AppThemeResource PrimaryText}"
                Clicked="BtnAgregar_Clicked">
            <Button.Shadow>
                <Shadow Brush="{toolkit:AppThemeResource Shadow}"
                        Offset="0,4" Radius="8" Opacity="0.5" />
            </Button.Shadow>
        </Button>

    </Grid>
</ContentPage>
