<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:views="clr-namespace:ContaBeeMovil.Views"
             x:Class="ContaBeeMovil.Pages.Perfil.ManualRegistroPage"
             Title="Nueva cuenta fiscal"
             BackgroundColor="#66000000">

    <Grid Padding="10">
        <!-- Tarjeta centrada -->
        <Border BackgroundColor="{toolkit:AppThemeResource SecondaryBackground}"
                VerticalOptions="Center"
                HorizontalOptions="Fill"
                StrokeShape="RoundRectangle 16"
                Stroke="{toolkit:AppThemeResource Accent1}"
                StrokeThickness="1"
                Padding="20">
            <Border.Shadow>
                <Shadow Brush="{toolkit:AppThemeResource Shadow}"
                        Offset="0,4"
                        Radius="16"
                        Opacity="0.4" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="12">

                <Label Text="Nueva cuenta fiscal"
                       FontAttributes="Bold"
                       FontSize="20"
                       HorizontalOptions="Center"
                       TextColor="{toolkit:AppThemeResource PrimaryText}" />
                <BoxView Style="{StaticResource Divider}" />

                <Entry x:Name="EntryName"
                       Placeholder="Nombre o Razón Social"
                       HeightRequest="44"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                       TextChanged="EntryName_TextChanged" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Entry x:Name="EntryRfc"
                           Placeholder="RFC"
                           MaxLength="13"
                           HeightRequest="44"
                           TextColor="{toolkit:AppThemeResource PrimaryText}"
                           PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                           TextChanged="EntryRfc_TextChanged" />
                    <views:SelectorFlotante x:Name="SelectorPersona"
                                            Titulo="Persona"
                                            Grid.Column="1" />
                </Grid>

                <Label x:Name="LabelCounter"
                       Text="0/13"
                       HorizontalOptions="End"
                       TextColor="{toolkit:AppThemeResource SecondaryText}">
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="RfcValidation">
                            <VisualState x:Name="Empty">
                                <VisualState.Setters>
                                    <Setter Property="TextColor" Value="{toolkit:AppThemeResource SecondaryText}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Valid">
                                <VisualState.Setters>
                                    <Setter Property="TextColor" Value="{toolkit:AppThemeResource Success}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Invalid">
                                <VisualState.Setters>
                                    <Setter Property="TextColor" Value="{toolkit:AppThemeResource Error}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Label>

                <Entry x:Name="EntryCp"
                       Placeholder="Código Postal"
                       Keyboard="Numeric"
                       MaxLength="5"
                       HeightRequest="44"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                       TextChanged="EntryCp_TextChanged" />

                <Label x:Name="LabelCpCounter"
                       Text="0/5"
                       HorizontalOptions="End"
                       TextColor="{toolkit:AppThemeResource SecondaryText}">
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CpValidation">
                            <VisualState x:Name="Empty">
                                <VisualState.Setters>
                                    <Setter Property="TextColor" Value="{toolkit:AppThemeResource SecondaryText}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Valid">
                                <VisualState.Setters>
                                    <Setter Property="TextColor" Value="{toolkit:AppThemeResource Success}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Invalid">
                                <VisualState.Setters>
                                    <Setter Property="TextColor" Value="{toolkit:AppThemeResource Error}" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Label>

                <views:SelectorFlotante x:Name="SelectorRegimen"
                                        Titulo="Regimen" />

                <CheckBox x:Name="ChkCompartido"
                          IsChecked="True"
                          IsVisible="False" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button x:Name="BtnCancel"
                            Text="Cancelar"
                            BackgroundColor="Transparent"
                            BorderColor="{toolkit:AppThemeResource Accent1}"
                            BorderWidth="1"
                            TextColor="{toolkit:AppThemeResource PrimaryText}"
                            CornerRadius="10"
                            HeightRequest="44"
                            Clicked="BtnCancel_Clicked" />
                    <Button x:Name="BtnRegistrar"
                            Grid.Column="1"
                            Text="Registrar"
                            BackgroundColor="{toolkit:AppThemeResource Primary}"
                            TextColor="{toolkit:AppThemeResource PrimaryText}"
                            CornerRadius="10"
                            HeightRequest="44"
                            IsEnabled="False"
                            Clicked="BtnRegistrar_Clicked">
                        <Button.Triggers>
                            <Trigger TargetType="Button" Property="IsEnabled" Value="False">
                                <Setter Property="BackgroundColor" Value="{toolkit:AppThemeResource Disabled}" />
                                <Setter Property="TextColor"       Value="{toolkit:AppThemeResource SecondaryText}" />
                                <Setter Property="Opacity"         Value="1" />
                            </Trigger>
                        </Button.Triggers>
                    </Button>
                </Grid>

            </VerticalStackLayout>
        </Border>
        <!-- Overlay de carga -->
        <Grid x:Name="LoadingOverlay"
              IsVisible="False"
              BackgroundColor="{toolkit:AppThemeResource Shadow}"
              InputTransparent="False">
            <ActivityIndicator IsRunning="True"
                               Color="{toolkit:AppThemeResource Primary}"
                               WidthRequest="48"
                               HeightRequest="48"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
