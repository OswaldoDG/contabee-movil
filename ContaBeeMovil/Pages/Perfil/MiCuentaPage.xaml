<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ContaBeeMovil.Pages.Perfil.MiCuentaPage"
             Title="Mi cuenta"
             BackgroundColor="{toolkit:AppThemeResource Background}"
             Shell.BackgroundColor="{toolkit:AppThemeResource AppBarPrimary}"
             Shell.TitleColor="{toolkit:AppThemeResource PrimaryText}"
             Shell.ForegroundColor="{toolkit:AppThemeResource PrimaryText}"
             Shell.TabBarIsVisible="False">
    <Grid RowDefinitions="*,Auto" Padding="10">

        <!-- ── Contenido superior (scroll si crece) ── -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="8">

                <Label Text="Cuenta"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="{toolkit:AppThemeResource SecondaryText}"
                   Margin="4,0,0,4" />

                <Border Style="{StaticResource ElevatedCard}" Padding="10">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCambiarContrasenaClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="4,Auto,*,Auto" ColumnSpacing="10">
                        <BoxView Grid.Column="0"
                             BackgroundColor="{toolkit:AppThemeResource Primary}"
                             WidthRequest="4" CornerRadius="2"
                             VerticalOptions="Fill" />
                        <mi:MauiIcon Grid.Column="1"
                                     Icon="{mi:Material Icon=Key}"
                                     IconSize="22"
                                     IconColor="{toolkit:AppThemeResource Icon}"
                                     VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                            <Label Text="Cambiar contraseña"
                               Style="{StaticResource Body1}" />
                            <Label Text="Actualiza tu contraseña de acceso"
                               FontSize="12"
                               TextColor="{toolkit:AppThemeResource SecondaryText}" />
                        </VerticalStackLayout>
                        <mi:MauiIcon Grid.Column="3"
                                     Icon="{mi:Material Icon=ChevronRight}"
                                     IconSize="16"
                                     IconColor="{toolkit:AppThemeResource SecondaryText}"
                                     VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- ── Legal ── -->
                <Label Text="Legal"
                   FontSize="13"
                   FontAttributes="Bold"
                   TextColor="{toolkit:AppThemeResource SecondaryText}"
                   Margin="4,8,0,4" />

                <Border Style="{StaticResource ElevatedCard}" Padding="10">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAvisoPrivacidadClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="4,Auto,*,Auto" ColumnSpacing="10">
                        <BoxView Grid.Column="0"
                             BackgroundColor="{toolkit:AppThemeResource Primary}"
                             WidthRequest="4" CornerRadius="2"
                             VerticalOptions="Fill" />
                        <mi:MauiIcon Grid.Column="1"
                                     Icon="{mi:Material Icon=Security}"
                                     IconSize="22"
                                     IconColor="{toolkit:AppThemeResource Icon}"
                                     VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                            <Label Text="Aviso de privacidad"
                               Style="{StaticResource Body1}" />
                            <Label Text="Consulta cómo manejamos tu información"
                               FontSize="12"
                               TextColor="{toolkit:AppThemeResource SecondaryText}" />
                        </VerticalStackLayout>
                        <mi:MauiIcon Grid.Column="3"
                                     Icon="{mi:Material Icon=ChevronRight}"
                                     IconSize="16"
                                     IconColor="{toolkit:AppThemeResource SecondaryText}"
                                     VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource ElevatedCard}" Padding="10">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTerminosServicioClicked" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="4,Auto,*,Auto" ColumnSpacing="10">
                        <BoxView Grid.Column="0"
                             BackgroundColor="{toolkit:AppThemeResource Primary}"
                             WidthRequest="4" CornerRadius="2"
                             VerticalOptions="Fill" />
                        <mi:MauiIcon Grid.Column="1"
                                     Icon="{mi:Material Icon=Description}"
                                     IconSize="22"
                                     IconColor="{toolkit:AppThemeResource Icon}"
                                     VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                            <Label Text="Términos del servicio"
                               Style="{StaticResource Body1}" />
                            <Label Text="Condiciones de uso de la aplicación"
                               FontSize="12"
                               TextColor="{toolkit:AppThemeResource SecondaryText}" />
                        </VerticalStackLayout>
                        <mi:MauiIcon Grid.Column="3"
                                     Icon="{mi:Material Icon=ChevronRight}"
                                     IconSize="16"
                                     IconColor="{toolkit:AppThemeResource SecondaryText}"
                                     VerticalOptions="Center" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Zona de peligro (siempre al fondo) ── -->
        <VerticalStackLayout Grid.Row="1" Spacing="8" Padding="0,12,0,0">

            <BoxView Style="{StaticResource Divider}" />

            <Label Text="Zona de peligro"
               FontSize="13"
               FontAttributes="Bold"
               TextColor="{toolkit:AppThemeResource Error}"
               Margin="4,0,0,4" />

            <Border Style="{StaticResource ElevatedCard}" Padding="10">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnEliminarCuentaClicked" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="4,Auto,*,Auto" ColumnSpacing="10">
                    <BoxView Grid.Column="0"
                         BackgroundColor="{toolkit:AppThemeResource Error}"
                         WidthRequest="4" CornerRadius="2"
                         VerticalOptions="Fill" />
                    <mi:MauiIcon Grid.Column="1"
                                 Icon="{mi:Material Icon=Delete}"
                                 IconSize="22"
                                 IconColor="{toolkit:AppThemeResource Error}"
                                 VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="1">
                        <Label Text="Eliminar cuenta"
                           Style="{StaticResource Body1}"
                           TextColor="{toolkit:AppThemeResource Error}" />
                        <Label Text="Esta acción es permanente e irreversible"
                           FontSize="10"
                           TextColor="{toolkit:AppThemeResource SecondaryText}" />
                    </VerticalStackLayout>
                    <mi:MauiIcon Grid.Column="3"
                                 Icon="{mi:Material Icon=ChevronRight}"
                                 IconSize="16"
                                 IconColor="{toolkit:AppThemeResource Error}"
                                 VerticalOptions="Center" />
                </Grid>
            </Border>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
