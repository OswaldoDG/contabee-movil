<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ContaBeeMovil.Pages.Perfil.RegistrarRFCsPage"
             Title="Registrar Cuenta Fiscal"
             BackgroundColor="{toolkit:AppThemeResource Background}"
             Shell.BackgroundColor="{toolkit:AppThemeResource AppBarSecondary}"
             Shell.TitleColor="{toolkit:AppThemeResource PrimaryText}"
             Shell.ForegroundColor="{toolkit:AppThemeResource PrimaryText}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="28">

            <!-- Registro Manual -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Registro manual"
                       FontAttributes="Bold"
                       FontSize="18"
                       TextColor="{toolkit:AppThemeResource PrimaryText}" />
                <Label Text="Sólo necesita ingresar los datos fiscales básicos."
                       FontSize="13"
                       TextColor="{toolkit:AppThemeResource SecondaryText}" />

                <Border WidthRequest="72"
                        HeightRequest="72"
                        HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        BackgroundColor="{toolkit:AppThemeResource Primary}">
                    <mi:MauiIcon Icon="{mi:Material Icon=Edit}"
                                 IconSize="32"
                                 IconColor="{toolkit:AppThemeResource PrimaryText}"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                        <mi:MauiIcon.GestureRecognizers>
                            <TapGestureRecognizer Tapped="IconManual_Tapped" />
                        </mi:MauiIcon.GestureRecognizers>
                    </mi:MauiIcon>
                </Border>
            </VerticalStackLayout>

            <!-- Registro QR -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Registro QR"
                       FontAttributes="Bold"
                       FontSize="18"
                       TextColor="{toolkit:AppThemeResource PrimaryText}" />
                <Label Text="Utilice la cámara del dispositivo para leer el QR de su constancia de situación fiscal."
                       FontSize="13"
                       TextColor="{toolkit:AppThemeResource SecondaryText}" />

                <Border WidthRequest="72"
                        HeightRequest="72"
                        HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        BackgroundColor="{toolkit:AppThemeResource Primary}">
                    <mi:MauiIcon Icon="{mi:Material Icon=QrCode}"
                                 IconSize="32"
                                 IconColor="{toolkit:AppThemeResource PrimaryText}"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                        <mi:MauiIcon.GestureRecognizers>
                            <TapGestureRecognizer Tapped="IconQr_Tapped" />
                        </mi:MauiIcon.GestureRecognizers>
                    </mi:MauiIcon>
                </Border>
            </VerticalStackLayout>

            <!-- Vincular -->
            <VerticalStackLayout Spacing="8" Padding="0,8,0,36">
                <Label Text="Vincularme"
                       FontAttributes="Bold"
                       FontSize="18"
                       TextColor="{toolkit:AppThemeResource PrimaryText}" />
                <Label Text="Esta opción permite conectar este dispositivo al grupo de trabajo de un usuario con una cuenta fiscal existente."
                       FontSize="13"
                       TextColor="{toolkit:AppThemeResource SecondaryText}" />

                <Border WidthRequest="72"
                        HeightRequest="72"
                        HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        BackgroundColor="{toolkit:AppThemeResource Primary}">
                    <mi:MauiIcon Icon="{mi:Material Icon=PersonAdd}"
                                 IconSize="32"
                                 IconColor="{toolkit:AppThemeResource PrimaryText}"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">
                        <mi:MauiIcon.GestureRecognizers>
                            <TapGestureRecognizer Tapped="IconVincular_Tapped" />
                        </mi:MauiIcon.GestureRecognizers>
                    </mi:MauiIcon>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
