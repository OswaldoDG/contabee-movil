<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ContaBeeMovil.Pages.Perfil.RegistrarRFCsPage"
             Title="Registrar Cuenta Fiscal"
             BackgroundColor="{toolkit:AppThemeResource Background}"
             Shell.BackgroundColor="{toolkit:AppThemeResource AppBarSecondary}"
             Shell.TitleColor="{toolkit:AppThemeResource PrimaryText}"
             Shell.ForegroundColor="{toolkit:AppThemeResource PrimaryText}">

    <Grid RowDefinitions="*,1,*">

        <!-- Registro Manual -->
        <VerticalStackLayout Grid.Row="0"
                             Padding="24,0"
                             Spacing="10"
                             VerticalOptions="Center">
            <Label Text="Registro manual"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="{toolkit:AppThemeResource PrimaryText}" />
            <Label Text="Sólo necesita ingresar los datos fiscales básicos."
                   FontSize="13"
                   TextColor="{toolkit:AppThemeResource SecondaryText}" />
            <Border WidthRequest="72"
                    HeightRequest="72"
                    Margin="0,6,0,0"
                    HorizontalOptions="Center"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0"
                    BackgroundColor="{toolkit:AppThemeResource Primary}">
                <mi:MauiIcon Icon="{mi:Material Icon=Edit}"
                             IconSize="32"
                             IconColor="{toolkit:AppThemeResource PrimaryText}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">
                    <mi:MauiIcon.GestureRecognizers>
                        <TapGestureRecognizer Tapped="IconManual_Tapped" />
                    </mi:MauiIcon.GestureRecognizers>
                </mi:MauiIcon>
            </Border>
        </VerticalStackLayout>

        <!-- Separador -->
        <BoxView Grid.Row="1"
                 Margin="24,0"
                 Color="{toolkit:AppThemeResource Accent1}" />

        <!-- Registro QR -->
        <VerticalStackLayout Grid.Row="2"
                             Padding="24,0"
                             Spacing="10"
                             VerticalOptions="Center">
            <Label Text="Registro QR"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="{toolkit:AppThemeResource PrimaryText}" />
            <Label Text="Utilice la cámara del dispositivo para leer el QR de su constancia de situación fiscal."
                   FontSize="13"
                   TextColor="{toolkit:AppThemeResource SecondaryText}" />
            <Border WidthRequest="72"
                    HeightRequest="72"
                    Margin="0,6,0,0"
                    HorizontalOptions="Center"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0"
                    BackgroundColor="{toolkit:AppThemeResource Primary}">
                <mi:MauiIcon Icon="{mi:Material Icon=QrCode}"
                             IconSize="32"
                             IconColor="{toolkit:AppThemeResource PrimaryText}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">
                    <mi:MauiIcon.GestureRecognizers>
                        <TapGestureRecognizer Tapped="IconQr_Tapped" />
                    </mi:MauiIcon.GestureRecognizers>
                </mi:MauiIcon>
            </Border>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
