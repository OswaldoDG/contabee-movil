<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ContaBeeMovil.Pages.Dev.LogsPage"
             BackgroundColor="{toolkit:AppThemeResource Background}"
             Title="Logs"
             Shell.TabBarIsVisible="False">
    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center" Padding="2">
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="1">
                <Label Text="Logs"
                       Style="{StaticResource Body1Strong}"
                       FontSize="15"/>
                <Label Text="{Binding Logs.Count, StringFormat='{0} entradas'}"
                       Style="{StaticResource Caption1}"
                       TextColor="{toolkit:AppThemeResource SecondaryText}"
                       FontSize="12" />
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    Text="Limpiar"
                    Style="{StaticResource CleanLogsButton}"
                    Clicked="OnLimpiarClicked"/>
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">

        <!-- Lista de logs -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Logs}"
                        Margin="0">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="8">
                    <mi:MauiIcon Icon="{mi:Material Icon=TextSnippet}"
                                 IconSize="48"
                                 HorizontalOptions="Center"
                                 IconColor="{toolkit:AppThemeResource SecondaryText}" />
                    <Label Text="No hay logs registrados"
                           Style="{StaticResource Body1}"
                           TextColor="{toolkit:AppThemeResource SecondaryText}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String" >
                    <Grid Padding="5,6"  ColumnDefinitions="*,Auto" >
<Label Grid.Column="0"
       Text="{Binding .}"
       Style="{StaticResource Caption1}"
       TextColor="{toolkit:AppThemeResource PrimaryText}"
       FontFamily="OpenSansRegular"
       LineBreakMode="WordWrap"
       VerticalOptions="Center"
       Margin="0,0,0,10"/>

<Button Grid.Column="1"
        mi:MauiIcon.Value="{mi:Material Icon=ContentCopy}"
        BackgroundColor="Transparent"
        Padding="6,0"
        VerticalOptions="Center"
        CommandParameter="{Binding .}"
        Clicked="OnCopiarLogClicked"/>

<BoxView Grid.Row="0"
         VerticalOptions="End"
         Style="{StaticResource Divider}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>
