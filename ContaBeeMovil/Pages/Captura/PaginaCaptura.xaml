<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:views="clr-namespace:ContaBeeMovil.Views"
             xmlns:f="clr-namespace:Fonts"
             xmlns:models="clr-namespace:ContaBeeMovil.Models"
             x:Class="ContaBeeMovil.Pages.Captura.PaginaCaptura"
             Title="Captura"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{toolkit:AppThemeResource Background}">

    <!-- Grid raíz: contenido + overlay de envío encima -->
    <Grid>

        <!-- ══════════════════════════════════════════════════════════════════════
             CONTENIDO PRINCIPAL
             ══════════════════════════════════════════════════════════════════════ -->
        <Grid RowDefinitions="Auto,*,Auto">

            <!-- ── Zona de controles (scroll por si el teclado sube) ───────────── -->
            <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Spacing="0" Padding="12,8,12,4">

                    <!-- 1. Barra RFC / CP -->
                    <views:RfcCpBarView Margin="-12,0" ConFondo="False" EnColumnas="True" />

                    <!-- Separador visual -->
                    <BoxView HeightRequest="1"
                             Margin="-12,0"
                             Color="{toolkit:AppThemeResource SecondaryBackground}" />

                    <!-- 2+3. Forma de pago y Tarjeta -->
                    <Grid ColumnDefinitions="*,*"
                          Margin="0,8,0,0"
                          ColumnSpacing="8">

                        <!-- Forma de pago -->
                        <views:SelectorFlotante Grid.Column="0"
                                               x:Name="SelectorFormaPago"
                                               Titulo="Medio Pago" />

                        <!-- Tarjeta / Agregar tarjeta -->
                        <Grid Grid.Column="1">
                            <views:SelectorFlotante x:Name="SelectorTarjeta"
                                                   IsVisible="{Binding MostrarSelectorTarjeta}"
                                                   Titulo="Tarjeta" />
                            <Border IsVisible="{Binding MostrarBotonAgregarTarjeta}"
                                    HorizontalOptions="Fill"
                                    BackgroundColor="{toolkit:AppThemeResource Background}"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1"
                                    Stroke="{toolkit:AppThemeResource Accent1}"
                                    Padding="0">
                                <Button Text="+ Tarjeta"
                                        HorizontalOptions="Fill"
                                        Command="{Binding IrAgregarTarjetaCommand}"
                                        FontSize="14"
                                        FontAttributes="Bold"
                                        BackgroundColor="Transparent"
                                        TextColor="{toolkit:AppThemeResource PrimaryText}"
                                        HeightRequest="44" />
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- 4+5. Uso CFDI + Desglosar IEPS -->
                    <Grid ColumnDefinitions="*,*"
                          Margin="0,8,0,0"
                          ColumnSpacing="8">
                        <views:SelectorFlotante Grid.Column="0"
                                               x:Name="SelectorUsoCfdi"
                                               Titulo="Uso Factura" />
                        <Border Grid.Column="1"
                                BackgroundColor="{toolkit:AppThemeResource Background}"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="1"
                                Stroke="{toolkit:AppThemeResource Accent1}"
                                Padding="8,0">
                            <HorizontalStackLayout Spacing="4"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center">
                                <CheckBox IsChecked="{Binding DesglosarIeps}"
                                          Color="{toolkit:AppThemeResource Primary}"
                                          VerticalOptions="Center" />
                                <Label Text="Desglosar IEPS"
                                       FontSize="13"
                                       VerticalOptions="Center"
                                       TextColor="{toolkit:AppThemeResource PrimaryText}" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <!-- 6. Notas adicionales -->
                    <Border Margin="0,8,0,0"
                            BackgroundColor="{toolkit:AppThemeResource Background}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="{toolkit:AppThemeResource Accent1}"
                            Padding="12,0">
                        <Entry Placeholder="Notas adicionales Opcional"
                               Text="{Binding NotasAdicionales}"
                               HeightRequest="44"
                               FontSize="14"
                               PlaceholderColor="{toolkit:AppThemeResource SecondaryText}"
                               TextColor="{toolkit:AppThemeResource PrimaryText}"
                               BackgroundColor="Transparent" />
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ── 7. Zona de capturas ─────────────────────────────────────────── -->
            <Grid Grid.Row="1">

                <!-- Estado vacío -->
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="8"
                                     IsVisible="{Binding TieneCapturas, Converter={StaticResource InvertedBoolConverter}}">
                    <Label Text="{x:Static f:FluentUI.document_multiple_20_regular}"
                           FontFamily="FluentUI"
                           FontSize="52"
                           HorizontalOptions="Center"
                           TextColor="{toolkit:AppThemeResource SecondaryText}" />
                    <Label Text="Sin Capturas"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{toolkit:AppThemeResource SecondaryText}" />
                    <Label Text="¡Vaya! Parece que no hay nada aquí"
                           FontSize="13"
                           HorizontalOptions="Center"
                           TextColor="{toolkit:AppThemeResource SecondaryText}" />
                </VerticalStackLayout>

                <!-- Lista horizontal de capturas -->
                <CollectionView ItemsSource="{Binding Capturas}"
                                IsVisible="{Binding TieneCapturas}">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CapturaLote">
                            <Grid Margin="6,4"
                                  WidthRequest="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=CapturaItemWidth}"
                                  HeightRequest="460"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center">
                                <!-- Imagen sin fondo, recortada con esquinas redondeadas -->
                                <Border StrokeShape="RoundRectangle 12"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent">
                                    <Image Source="{Binding Path, Converter={StaticResource FilePathToImageConverter}}"
                                           Aspect="AspectFill"
                                           HorizontalOptions="Fill"
                                           VerticalOptions="Fill">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=VerImagenCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Image.GestureRecognizers>
                                    </Image>
                                </Border>

                                <!-- Botón eliminar superpuesto, centro inferior -->
                                <Button HorizontalOptions="Center"
                                        VerticalOptions="End"
                                        Margin="0,0,0,10"
                                        Text="{x:Static f:FluentUI.delete_20_regular}"
                                        FontFamily="FluentUI"
                                        FontSize="22"
                                        BackgroundColor="Transparent"
                                        TextColor="{toolkit:AppThemeResource Error}"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        Padding="0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=EliminarCapturaCommand}"
                                        CommandParameter="{Binding .}">
                                    <Button.Shadow>
                                        <Shadow Brush="Black" Offset="0,0" Radius="6" Opacity="0.9" />
                                    </Button.Shadow>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </Grid>

            <!-- ── Barra de acciones: sin capturas (Cancelar + Cámara al 50%) ── -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*"
                  Padding="12,8,12,12"
                  ColumnSpacing="8"
                  BackgroundColor="{toolkit:AppThemeResource Background}"
                  IsVisible="{Binding TieneCapturas, Converter={StaticResource InvertedBoolConverter}}">

                <Button Grid.Column="0"
                        Text="Cancelar"
                        Command="{Binding CancelarCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{toolkit:AppThemeResource PrimaryText}"
                        BorderColor="{toolkit:AppThemeResource SecondaryText}"
                        BorderWidth="1.5"
                        CornerRadius="12"
                        HeightRequest="52"
                        FontSize="15" />

                <Button Grid.Column="1"
                        Text="{x:Static f:FluentUI.camera_28_regular}"
                        FontFamily="FluentUI"
                        FontSize="26"
                        Command="{Binding TomarFotoCommand}"
                        IsEnabled="{Binding EstaEnviando, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="{toolkit:AppThemeResource Primary}"
                        TextColor="{toolkit:AppThemeResource PrimaryText}"
                        CornerRadius="12"
                        HeightRequest="52">
                    <Button.Shadow>
                        <Shadow Brush="{toolkit:AppThemeResource Shadow}" Offset="0,3" Radius="6" Opacity="0.35" />
                    </Button.Shadow>
                </Button>

            </Grid>

            <!-- ── Barra de acciones: con capturas (Cancelar + Cámara + Enviar al 33%) ── -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*,*"
                  Padding="12,8,12,12"
                  ColumnSpacing="8"
                  BackgroundColor="{toolkit:AppThemeResource Background}"
                  IsVisible="{Binding TieneCapturas}">

                <Button Grid.Column="0"
                        Text="Cancelar"
                        Command="{Binding CancelarCommand}"
                        IsEnabled="{Binding EstaEnviando, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="Transparent"
                        TextColor="{toolkit:AppThemeResource PrimaryText}"
                        BorderColor="{toolkit:AppThemeResource SecondaryText}"
                        BorderWidth="1.5"
                        CornerRadius="12"
                        HeightRequest="52"
                        FontSize="15" />

                <Button Grid.Column="1"
                        Text="{x:Static f:FluentUI.camera_28_regular}"
                        FontFamily="FluentUI"
                        FontSize="26"
                        Command="{Binding TomarFotoCommand}"
                        IsEnabled="{Binding EstaEnviando, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="{toolkit:AppThemeResource Primary}"
                        TextColor="{toolkit:AppThemeResource PrimaryText}"
                        CornerRadius="12"
                        HeightRequest="52">
                    <Button.Shadow>
                        <Shadow Brush="{toolkit:AppThemeResource Shadow}" Offset="0,3" Radius="6" Opacity="0.35" />
                    </Button.Shadow>
                </Button>

                <Button Grid.Column="2"
                        Text="Enviar"
                        Command="{Binding EnviarCommand}"
                        IsEnabled="{Binding PuedeEnviar}"
                        BackgroundColor="{toolkit:AppThemeResource Primary}"
                        TextColor="{toolkit:AppThemeResource PrimaryText}"
                        CornerRadius="12"
                        HeightRequest="52"
                        Padding="14,0"
                        FontSize="15"
                        FontAttributes="Bold"
                        ContentLayout="Left,6">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding PuedeEnviar}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="{toolkit:AppThemeResource Disabled}" />
                            <Setter Property="Shadow" Value="{x:Null}" />
                        </DataTrigger>
                    </Button.Triggers>
                    <Button.Shadow>
                        <Shadow Brush="{toolkit:AppThemeResource Shadow}" Offset="0,3" Radius="6" Opacity="0.35" />
                    </Button.Shadow>
                    <Button.ImageSource>
                        <FontImageSource FontFamily="FluentUI"
                                         Glyph="{x:Static f:FluentUI.arrow_upload_20_regular}"
                                         Size="18"
                                         Color="{toolkit:AppThemeResource PrimaryText}" />
                    </Button.ImageSource>
                </Button>

            </Grid>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════════
             OVERLAY DE ENVÍO
             ══════════════════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding EstaEnviando}"
              BackgroundColor="{toolkit:AppThemeResource Background}"
              InputTransparent="False">

            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="24"
                                 Padding="40">

                <Label Text="Enviando Capturas ..."
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{toolkit:AppThemeResource PrimaryText}" />

                <!-- Círculo de progreso -->
                <Grid WidthRequest="160" HeightRequest="160"
                      HorizontalOptions="Center">
                    <GraphicsView x:Name="CircularProgress"
                                  WidthRequest="160"
                                  HeightRequest="160"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center" />
                    <Label Text="{Binding EnviandoProgreso, StringFormat='{0:P0}'}"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="{toolkit:AppThemeResource PrimaryText}" />
                </Grid>

            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>
