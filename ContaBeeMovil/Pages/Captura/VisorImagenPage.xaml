<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ContaBeeMovil.Pages.Captura.VisorImagenPage"
             Title=""
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">

    <Grid RowDefinitions="Auto,*">

        <!-- Barra superior -->
        <Grid Grid.Row="0" Padding="12,50,12,12">
            <Button HorizontalOptions="Start"
                    Text="←"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    Clicked="OnCerrar" />
        </Grid>

        <!-- Área de imagen con zoom/pan -->
        <ScrollView Grid.Row="1"
                    x:Name="ImgScrollView"
                    Orientation="Both"
                    HorizontalScrollBarVisibility="Never"
                    VerticalScrollBarVisibility="Never">
            <Image x:Name="ImgVisor"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <PinchGestureRecognizer PinchUpdated="OnPinchUpdated" />
                    <PanGestureRecognizer PanUpdated="OnPanUpdated" />
                    <TapGestureRecognizer NumberOfTapsRequired="2" Tapped="OnDoubleTap" />
                </Image.GestureRecognizers>
            </Image>
        </ScrollView>

    </Grid>
</ContentPage>
