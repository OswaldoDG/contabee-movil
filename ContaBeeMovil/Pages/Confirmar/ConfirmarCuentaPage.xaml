<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ContaBeeMovil.Pages.Confirmar.ConfirmarCuentaPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid>
        <!-- Barra superior color dorado -->
        <BoxView BackgroundColor="#F5C000"
                 HeightRequest="60"
                 VerticalOptions="Start"/>

        <!-- Tarjeta central -->
        <Frame Margin="24,40,24,24"
               CornerRadius="16"
               Padding="32"
               BackgroundColor="White"
               HasShadow="True"
               VerticalOptions="Center">

            <StackLayout Spacing="0">

                <!-- Ícono superior: cambia según estado -->
                <Grid HorizontalOptions="Center"
                      Margin="0,0,0,40">

                    <!-- Loading -->
                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsRunning="True"
                                       IsVisible="True"
                                       Color="#F5C000"
                                       WidthRequest="80"
                                       HeightRequest="80"/>

                    <!-- Éxito -->
                    <Frame x:Name="SuccessIcon"
                           IsVisible="False"
                           WidthRequest="90"
                           HeightRequest="90"
                           CornerRadius="45"
                           BackgroundColor="#F5C000"
                           Padding="0"
                           HorizontalOptions="Center"
                           HasShadow="False">
                        <Label Text="✓"
                               FontSize="44"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Frame>

                    <!-- Error -->
                    <Frame x:Name="ErrorIcon"
                           IsVisible="False"
                           WidthRequest="90"
                           HeightRequest="90"
                           CornerRadius="45"
                           BackgroundColor="#E53935"
                           Padding="0"
                           HorizontalOptions="Center"
                           HasShadow="False">
                        <Label Text="✕"
                               FontSize="44"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Frame>
                </Grid>

                <!-- Título -->
                <Label x:Name="TituloLabel"
                       Text="Verificando tu cuenta..."
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#1A1A1A"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,12"/>

                <!-- Mensaje -->
                <Label x:Name="MensajeLabel"
                       Text="Por favor espera un momento."
                       FontSize="15"
                       TextColor="{toolkit:AppThemeResource SecondaryText}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,48"/>

                <!-- Botón Continuar -->
                <Button x:Name="ContinuarBtn"
                        Text="Continuar"
                        IsVisible="False"
                        BackgroundColor="#EEEEEE"
                        TextColor="#1A1A1A"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="52"
                        Clicked="OnContinuarClicked"/>

            </StackLayout>
        </Frame>
    </Grid>

</ContentPage>