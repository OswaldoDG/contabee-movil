<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ContaBeeMovil.Pages.MainTabbedPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:ContaBeeMovil.Controls"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
    xmlns:vm="clr-namespace:ContaBeeMovil.Pages.Dashboard"
    xmlns:views="clr-namespace:ContaBeeMovil.Views"
    Shell.TabBarIsVisible="False"
    Shell.NavBarIsVisible="True"
    Shell.BackgroundColor="{DynamicResource CurrentShellBarColor}"
    BackgroundColor="Transparent">

    <Shell.TitleView>
        <Grid>
            <Grid x:Name="MonthNavBar"
                  x:DataType="vm:DashboardViewModel"
                  ColumnDefinitions="Auto,*,Auto"
                  VerticalOptions="Center"
                  HorizontalOptions="Fill"
                  Padding="0">
                <mi:MauiIcon Grid.Column="0"
                             Icon="{mi:Material Icon=ChevronLeft}"
                             IconColor="{toolkit:AppThemeResource Icon}"
                             IconSize="30"
                             BackgroundColor="Transparent"
                             VerticalOptions="Center">
                    <mi:MauiIcon.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding MesAnteriorCommand}" />
                    </mi:MauiIcon.GestureRecognizers>
                </mi:MauiIcon>

                <Label Grid.Column="1"
                       Text="{Binding MesAnioTexto}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

                <mi:MauiIcon Grid.Column="2"
                             Icon="{mi:Material Icon=ChevronRight}"
                             IconColor="{toolkit:AppThemeResource Icon}"
                             IconSize="30"
                             BackgroundColor="Transparent"
                             VerticalOptions="Center"
                             Margin="0,0,30,0">
                    <mi:MauiIcon.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding MesSiguienteCommand}" />
                    </mi:MauiIcon.GestureRecognizers>
                </mi:MauiIcon>
            </Grid>
            <Label x:Name="LabelTitulo"
                   FontSize="25"
                   FontAttributes="Bold"
                   TextColor="{toolkit:AppThemeResource PrimaryText}"
                   VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="*,Auto">

        <!-- Área de contenido dinámico -->
        <ContentView x:Name="PageContainer"
                 Grid.Row="0" />

        <!-- Contenedor con fondo para la zona inferior -->
        <Border Grid.Row="1"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 1,1,0,0"
                BackgroundColor="{toolkit:AppThemeResource Background}"
                Padding="0">
            <Border.Shadow>
                <Shadow Brush="Black"
                        Radius="1"
                        Opacity="0.1"
                        Offset="0,-1" />
            </Border.Shadow>
            <Grid RowDefinitions="Auto,Auto">
                <views:RfcCpBarView Grid.Row="0" />
                <controls:SimpleTabBar x:Name="TabBar"
                                       Grid.Row="1"
                                       TabChanged="OnTabChanged" />
            </Grid>
        </Border>

    </Grid>

</ContentPage>
