<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:views="clr-namespace:ContaBeeMovil.Views"
    x:Class="ContaBeeMovil.Pages.Camara.QRPage"
    Title="Escanear QR"
    BackgroundColor="{toolkit:AppThemeResource Background}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="16" RowSpacing="12">

        <!-- Tipo de persona y compartido -->
        <VerticalStackLayout Grid.Row="0" Spacing="8" Padding="0,4">
            <Label Text="Tipo de persona"
                   FontAttributes="Bold"
                   TextColor="{toolkit:AppThemeResource PrimaryText}" />
            <HorizontalStackLayout Spacing="8">
                <views:SelectorFlotante WidthRequest="160"
                                        Titulo="Seleccione..."
                                        Elementos="{Binding TiposPersona}"
                                        ElementoSeleccionado="{Binding TipoPersona}" />
                <HorizontalStackLayout VerticalOptions="Center" Spacing="8">
                    <Label Text="Compartido"
                           VerticalOptions="Center"
                           TextColor="{toolkit:AppThemeResource PrimaryText}" />
                    <Switch IsToggled="{Binding Compartido}" />
                </HorizontalStackLayout>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Scanner en tiempo real -->
        <Grid Grid.Row="1" x:Name="CameraGrid">
            <zxing:CameraBarcodeReaderView
                x:Name="BarcodeReader"
                BarcodesDetected="OnBarcodesDetected" />

            <!-- Guía visual de encuadre -->
            <Border StrokeShape="RoundRectangle 10"
                    Stroke="White"
                    StrokeThickness="2"
                    BackgroundColor="Transparent"
                    WidthRequest="220"
                    HeightRequest="220"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    InputTransparent="True" />
        </Grid>

        <!-- Overlay de carga (span en todas las filas) -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="3"
              IsVisible="False"
              BackgroundColor="{toolkit:AppThemeResource Shadow}"
              InputTransparent="False">
            <ActivityIndicator IsRunning="True"
                               Color="{toolkit:AppThemeResource Primary}"
                               WidthRequest="48"
                               HeightRequest="48"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>

        <!-- Cancelar -->
        <Button Grid.Row="2"
                Text="Cancelar"
                HeightRequest="52"
                CornerRadius="12"
                FontAttributes="Bold"
                FontSize="16"
                BackgroundColor="{toolkit:AppThemeResource Primary}"
                TextColor="White"
                Clicked="BtnCancelar_Clicked" />

    </Grid>
</ContentPage>
