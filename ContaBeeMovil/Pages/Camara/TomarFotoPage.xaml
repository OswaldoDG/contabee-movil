<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="ContaBeeMovil.Pages.Camara.TomarFotoPage"
    Title="Tomar Foto"
    BackgroundColor="{toolkit:AppThemeResource Background}">

    <Grid RowDefinitions="*, Auto" Padding="24" RowSpacing="16">

        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 16"
                Stroke="{toolkit:AppThemeResource Accent1}"
                StrokeThickness="1"
                BackgroundColor="{toolkit:AppThemeResource SecondaryBackground}">
            <Grid>
                <VerticalStackLayout
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    IsVisible="{Binding HasPhoto, Converter={StaticResource InvertedBoolConverter}}">
                    <Label Text="📷" FontSize="52" HorizontalOptions="Center" />
                    <Label Text="Presiona el botón para tomar una foto"
                           FontSize="14"
                           HorizontalOptions="Center"
                           Margin="0,8,0,0"
                           TextColor="{toolkit:AppThemeResource SecondaryText}" />
                </VerticalStackLayout>

                <Image Source="{Binding PhotoPath}"
                       Aspect="AspectFill"
                       IsVisible="{Binding HasPhoto}" />
            </Grid>
        </Border>

        <Button Grid.Row="1"
                Text="Tomar Foto"
                Command="{Binding TomarFotoCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                HeightRequest="52"
                CornerRadius="12"
                FontAttributes="Bold"
                FontSize="16"
                BackgroundColor="{toolkit:AppThemeResource Primary}"
                TextColor="{toolkit:AppThemeResource PrimaryText}" />

    </Grid>
</ContentPage>
