<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:views="clr-namespace:ContaBeeMovil.Views"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="ContaBeeMovil.Pages.FacturacionPage"
             Shell.BackgroundColor="{toolkit:AppThemeResource AppBarPrimary}"
             Title="Comprobantes">

    <Border Grid.Row="0"
            Padding="0"
            BackgroundColor="{toolkit:AppThemeResource Accent1}"
            StrokeShape="RoundRectangle 1,1,0,0">
        <Grid RowDefinitions="Auto,*">

        <!-- Controles de consulta -->
            <VerticalStackLayout>
                <views:FiltrosFacturasView x:Name="PanelFiltros"
                                   BuscarCommand="{Binding BuscarFacturasCommand}" />

                <!-- Banner: sin créditos de captura -->
                <Border IsVisible="{Binding SinCreditos}"
                StrokeShape="RoundRectangle 10"
                Stroke="{toolkit:AppThemeResource Primary}"
                StrokeThickness="0"
                BackgroundColor="{toolkit:AppThemeResource Primary}"
                Padding="10,5"
                Margin="8,2,8,4">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <mi:MauiIcon Grid.Column="0"
                                     Icon="{mi:Material Icon=Warning}"
                                     IconSize="18"
                                     IconColor="{toolkit:AppThemeResource Icon}"
                                     VerticalOptions="Center" />
                        <Label Grid.Column="1"
                       Text="No tienes créditos de captura disponibles."
                       FontSize="13"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       LineBreakMode="WordWrap"
                       VerticalOptions="Center" />
                    </Grid>
                </Border>
            </VerticalStackLayout>


        <!-- Lista de resultados + FAB -->
        <Grid Grid.Row="1">
        <views:ResultadosListaView
                                   EstaCargando="{Binding EstaCargando}"
                                   Elementos="{Binding Elementos}"
                                   TotalEncontrados="{Binding TotalEncontrados}"
                                   PaginaActual="{Binding PaginaActual}"
                                   TotalPaginas="{Binding TotalPaginas}"
                                   ConsultaEjecutada="{Binding ConsultaEjecutada}"
                                   AnteriorCommand="{Binding PaginaAnteriorCommand}"
                                   SiguienteCommand="{Binding PaginaSiguienteCommand}">
            <views:ResultadosListaView.PlantillaItem>
                <DataTemplate>
                    <views:LoteCapturaCardView />
                </DataTemplate>
            </views:ResultadosListaView.PlantillaItem>
        </views:ResultadosListaView>

            <!-- FAB Captura -->
            <Border WidthRequest="44" HeightRequest="44"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0"
                    Padding="0"
                    BackgroundColor="{toolkit:AppThemeResource Primary}"
                    HorizontalOptions="End" VerticalOptions="End"
                    Margin="0,0,8,8">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding SinCreditos}" Value="True">
                        <Setter Property="BackgroundColor" Value="{toolkit:AppThemeResource Disabled}" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAbrirCaptura" />
                </Border.GestureRecognizers>
                <mi:MauiIcon Icon="{mi:Material Icon=PhotoCamera}"
                             IconSize="20"
                             IconColor="#1A1A1A"
                             HorizontalOptions="Center"
                             VerticalOptions="Center" />
            </Border>

        </Grid>

    </Grid>
    </Border>

</ContentPage>
