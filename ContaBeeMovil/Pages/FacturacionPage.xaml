<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:views="clr-namespace:ContaBeeMovil.Views"
             xmlns:f="clr-namespace:Fonts"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="ContaBeeMovil.Pages.FacturacionPage"
             Title="Facturación">
    
    <Border Grid.Row="0"
            Padding="0"
            BackgroundColor="{toolkit:AppThemeResource Accent1}"
            StrokeShape="RoundRectangle 0"
            StrokeThickness="0">
        <Grid RowDefinitions="Auto,*">

        <!-- Controles de consulta -->
            <VerticalStackLayout>
                <views:FiltrosFacturasView x:Name="PanelFiltros"
                                   BuscarCommand="{Binding BuscarFacturasCommand}" />

                <!-- Banner: sin créditos de captura -->
                <Border IsVisible="{Binding SinCreditos}"
                StrokeShape="RoundRectangle 10"
                Stroke="{toolkit:AppThemeResource Primary}"
                StrokeThickness="0"
                BackgroundColor="{toolkit:AppThemeResource Primary}"
                Padding="12,5"
                Margin="12,0,12,4">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                       Text="{x:Static f:FluentUI.warning_20_regular}"
                       FontFamily="FluentUI"
                       FontSize="18"
                       TextColor="{toolkit:AppThemeResource Icon}"
                       VerticalOptions="Center" />
                        <Label Grid.Column="1"
                       Text="No tienes créditos de captura disponibles."
                       FontSize="13"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       LineBreakMode="WordWrap"
                       VerticalOptions="Center" />
                    </Grid>
                </Border>
            </VerticalStackLayout>


        <!-- Lista de resultados + FAB -->
        <Grid Grid.Row="1">
        <views:ResultadosListaView
                                   EstaCargando="{Binding EstaCargando}"
                                   Elementos="{Binding Elementos}"
                                   TotalEncontrados="{Binding TotalEncontrados}"
                                   PaginaActual="{Binding PaginaActual}"
                                   TotalPaginas="{Binding TotalPaginas}"
                                   ConsultaEjecutada="{Binding ConsultaEjecutada}"
                                   AnteriorCommand="{Binding PaginaAnteriorCommand}"
                                   SiguienteCommand="{Binding PaginaSiguienteCommand}">
            <views:ResultadosListaView.PlantillaItem>
                <DataTemplate>
                    <views:LoteCapturaCardView />
                </DataTemplate>
            </views:ResultadosListaView.PlantillaItem>
        </views:ResultadosListaView>

            <!-- FAB Captura -->
            <Border WidthRequest="60" HeightRequest="60"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    BackgroundColor="{toolkit:AppThemeResource Primary}"
                    HorizontalOptions="End" VerticalOptions="End"
                    Margin="0,0,16,5">
                <Border.Shadow>
                    <Shadow Brush="{toolkit:AppThemeResource Shadow}" Offset="0,4" Radius="8" Opacity="0.5" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAbrirCaptura" />
                </Border.GestureRecognizers>
                <mi:MauiIcon Icon="{mi:Material Icon=PhotoCamera}"
                             IconColor="{toolkit:AppThemeResource PrimaryText}"
                             IconSize="28"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             BackgroundColor="Transparent"
                             Padding="0" />
            </Border>

        </Grid>

    </Grid>
    </Border>

</ContentPage>
