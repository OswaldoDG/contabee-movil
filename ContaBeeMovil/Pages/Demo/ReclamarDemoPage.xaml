<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ContaBeeMovil.Pages.Demo.ReclamarDemoPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{toolkit:AppThemeResource SecondaryBackground}">

    <Grid>
        <BoxView BackgroundColor="{toolkit:AppThemeResource Primary}"
                 HeightRequest="60"
                 VerticalOptions="Start"/>

        <Border Margin="24,40,24,24"
                StrokeShape="RoundRectangle 16"
                Stroke="Transparent"
                Padding="32"
                BackgroundColor="{toolkit:AppThemeResource Alternate}"
                VerticalOptions="Center">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.2"/>
            </Border.Shadow>
            <StackLayout Spacing="0">

                <!-- Ícono de estado -->
                <Grid HorizontalOptions="Center" Margin="0,0,0,32">

                    <!-- Cargando -->
                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsRunning="True"
                                       IsVisible="True"
                                       Color="{toolkit:AppThemeResource Primary}"
                                       WidthRequest="80"
                                       HeightRequest="80"/>

                    <!-- Éxito -->
                    <Border x:Name="SuccessIcon"
                            IsVisible="False"
                            WidthRequest="90"
                            HeightRequest="90"
                            StrokeShape="RoundRectangle 45"
                            Stroke="Transparent"
                            BackgroundColor="{toolkit:AppThemeResource Primary}"
                            Padding="0"
                            HorizontalOptions="Center">
                        <Label Text="✓"
                               FontSize="44"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <!-- Error -->
                    <Border x:Name="ErrorIcon"
                            IsVisible="False"
                            WidthRequest="90"
                            HeightRequest="90"
                            StrokeShape="RoundRectangle 45"
                            Stroke="Transparent"
                            BackgroundColor="#E53935"
                            Padding="0"
                            HorizontalOptions="Center">
                        <Label Text="✕"
                               FontSize="44"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                </Grid>

                <!-- Título -->
                <Label x:Name="TituloLabel"
                       Text="Activando créditos..."
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{toolkit:AppThemeResource PrimaryText}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,12"/>

                <!-- Subtítulo -->
                <Label x:Name="MensajeLabel"
                       Text="Por favor espera un momento."
                       FontSize="15"
                       TextColor="{toolkit:AppThemeResource SecondaryText}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,8"/>

                <!-- RFC (visible solo en éxito) -->
                <StackLayout x:Name="RfcPanel"
                             IsVisible="False"
                             Spacing="2"
                             Margin="0,16,0,32">
                    <Label Text="Créditos otorgados a"
                           FontSize="13"
                           TextColor="{toolkit:AppThemeResource SecondaryText}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Label x:Name="RfcLabel"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{toolkit:AppThemeResource PrimaryText}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </StackLayout>

                <!-- Botón Continuar -->
                <Button x:Name="ContinuarBtn"
                        Text="Continuar"
                        IsVisible="False"
                        BackgroundColor="#EEEEEE"
                        TextColor="{toolkit:AppThemeResource PrimaryText}"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="52"
                        Clicked="OnContinuarClicked"/>

            </StackLayout>
        </Border>
    </Grid>

</ContentPage>
