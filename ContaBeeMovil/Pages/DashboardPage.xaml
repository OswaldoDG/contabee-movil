<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:views="clr-namespace:ContaBeeMovil.Views"
             xmlns:vm="clr-namespace:ContaBeeMovil.Pages.Dashboard"
             x:Class="ContaBeeMovil.Pages.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             BackgroundColor="{toolkit:AppThemeResource Background}">

    <Grid RowDefinitions="Auto,*">

        <!-- Banner: reclamar créditos demo -->
        <Border Grid.Row="0"
                IsVisible="{Binding PuedeReclamarDemo}"
                StrokeShape="RoundRectangle 24"
                Stroke="Transparent"
                StrokeThickness="0"
                BackgroundColor="Transparent"
                Padding="5,5"
                Margin="1,1,1,0"
                HorizontalOptions="Center">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ReclamarDemoCommand}" />
            </Border.GestureRecognizers>

            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="0" VerticalOptions="Center">

                <!-- Texto -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 24"
                        Stroke="Transparent"
                        StrokeThickness="0"
                        BackgroundColor="{toolkit:AppThemeResource Primary}"
                        Padding="5,5"
                        VerticalOptions="End">
                    <Border.Shadow>
                        <Shadow Brush="{toolkit:AppThemeResource Shadow}" Offset="0,4" Radius="8" Opacity="0.3" />
                    </Border.Shadow>
                    <Label Text="Empieza con créditos gratis"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{toolkit:AppThemeResource PrimaryText}"
                           VerticalOptions="End" />
                </Border>

                <!-- Icono grande sobresaliendo -->
                <Image Grid.Column="1"
                       Source="{AppThemeBinding Light=regalo_claro.png, Dark=regalo_oscuro.png}"
                       WidthRequest="72"
                       HeightRequest="72"
                       Aspect="AspectFit"
                       VerticalOptions="End"
                       Margin="-8,0,0,0" />
            </Grid>
        </Border>

        <views:ActividadView Grid.Row="1" />

    </Grid>

</ContentPage>
