<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:views="clr-namespace:ContaBeeMovil.Views"
             xmlns:vm="clr-namespace:ContaBeeMovil.Pages.Dashboard"
             x:Class="ContaBeeMovil.Pages.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Shell.BackgroundColor="{toolkit:AppThemeResource AppBarPrimary}"
             BackgroundColor="{toolkit:AppThemeResource Background}"
             Padding="0">

    <Grid RowDefinitions="Auto,*" Padding="0">

        <!--Banner: cupones disponibles-->
        <Border Grid.Row="0"
                IsVisible="{Binding TieneCuponBienvenida}"
                StrokeShape="RoundRectangle 10"
                Stroke="{toolkit:AppThemeResource Secondary}"
                StrokeThickness="1.5"
                BackgroundColor="{AppThemeBinding Light=#FFF8E1, Dark=#282828}"
                Padding="10,10"
                HorizontalOptions="Center"
                Margin="12,5,12,0">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding VerCuponesCommand}" />
            </Border.GestureRecognizers>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" VerticalOptions="Center">
                <Image Grid.Column="0"
                       Source="{AppThemeBinding Light=cupon_claro.png, Dark=cupon_oscuro.png}"
                       WidthRequest="42"
                       HeightRequest="42"
                       Aspect="AspectFit"
                       VerticalOptions="Center" />
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                    <Label Text="¡Tienes cupones disponibles!"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#ce8509, Dark=#fefdfc}"
                           VerticalOptions="Center" />
                    <Label Text="Toca aquí para ver tus cupones"
                           FontSize="12"
                           TextColor="{toolkit:AppThemeResource SecondaryText}"
                           VerticalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <views:ActividadView Grid.Row="1" />

    </Grid>

</ContentPage>
