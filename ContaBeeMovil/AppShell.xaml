<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ContaBeeMovil.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:f="clr-namespace:Fonts"
    xmlns:pages="clr-namespace:ContaBeeMovil.Pages"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
    Shell.FlyoutBehavior="Flyout"
    Shell.BackgroundColor="{toolkit:AppThemeResource AppBarPrimary}"
    Shell.TitleColor="{toolkit:AppThemeResource PrimaryText}"
    Shell.ForegroundColor="{toolkit:AppThemeResource PrimaryText}"
    Shell.TabBarBackgroundColor="{toolkit:AppThemeResource Primary}"
    Shell.TabBarForegroundColor="White"
    Shell.TabBarUnselectedColor="#AAFFFFFF"
    Shell.TabBarTitleColor="White"
    Title="ContaBee">

    <!-- ══════════════════════════════════════════ -->
    <!--  FLYOUT PERSONALIZADO                      -->
    <!-- ══════════════════════════════════════════ -->
    <Shell.FlyoutContent>
        <Grid RowDefinitions="Auto,*,Auto"
              BackgroundColor="{toolkit:AppThemeResource Background}">

            <!-- ── HEADER ── -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="Auto,*"
                  ColumnSpacing="14"
                  Padding="20,20,20,20"
                  BackgroundColor="{toolkit:AppThemeResource Background}">
                <Image Grid.Column="0"
                       Source="logo512.png"
                       WidthRequest="48"
                       HeightRequest="48" />
                <VerticalStackLayout Grid.Column="1"
                                     VerticalOptions="Center"
                                     Spacing="2">
                    <Label x:Name="LabelNombreUsuario"
                           Text="Usuario"
                           Style="{StaticResource Body1Strong}" />
                </VerticalStackLayout>
            </Grid>
            <BoxView Grid.Row="0"
                     VerticalOptions="End"
                     Style="{StaticResource Divider}" />

            <!-- ── BODY ── -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="16,12" Spacing="8">

                    <!-- ─── Cards de perfil ─── -->
                    <!--<Border Style="{StaticResource ElevatedCard}" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnVincularmeClicked" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="4,Auto,*,Auto" ColumnSpacing="12">
                            <BoxView Grid.Column="0"
                                     BackgroundColor="{toolkit:AppThemeResource Primary}"
                                     WidthRequest="4" CornerRadius="2"
                                     VerticalOptions="Fill" />
                            <Label Grid.Column="1"
                                   Text="{x:Static f:FluentUI.person_link_24_regular}"
                                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                                   FontSize="22"
                                   TextColor="{toolkit:AppThemeResource Primary}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="Vincularme"
                                   Style="{StaticResource Body1}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="3"
                                   Text="{x:Static f:FluentUI.chevron_right_20_regular}"
                                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                                   FontSize="16"
                                   TextColor="{toolkit:AppThemeResource SecondaryText}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>-->
                    <Border Style="{StaticResource ElevatedCard}" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTiendaClicked" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="4,Auto,*,Auto" ColumnSpacing="12">
                            <BoxView Grid.Column="0"
                                     BackgroundColor="{toolkit:AppThemeResource Primary}"
                                     WidthRequest="4" CornerRadius="2"
                                     VerticalOptions="Fill" />
                            <Label Grid.Column="1"
                                   Text="{x:Static f:FluentUI.shopping_bag_24_regular}"
                                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                                   FontSize="22"
                                   TextColor="{toolkit:AppThemeResource Icon}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="Tienda"
                                   Style="{StaticResource Body1}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="3"
                                   Text="{x:Static f:FluentUI.chevron_right_20_regular}"
                                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                                   FontSize="16"
                                   TextColor="{toolkit:AppThemeResource SecondaryText}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource ElevatedCard}" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTarjetasClicked" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="4,Auto,*,Auto" ColumnSpacing="12">
                            <BoxView Grid.Column="0"
                                     BackgroundColor="{toolkit:AppThemeResource Primary}"
                                     WidthRequest="4" CornerRadius="2"
                                     VerticalOptions="Fill" />
                            <Label Grid.Column="1"
                                   Text="{x:Static f:FluentUI.payment_24_regular}"
                                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                                   FontSize="22"
                                   TextColor="{toolkit:AppThemeResource Icon}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="Tarjetas"
                                   Style="{StaticResource Body1}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="3"
                                   Text="{x:Static f:FluentUI.chevron_right_20_regular}"
                                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                                   FontSize="16"
                                   TextColor="{toolkit:AppThemeResource SecondaryText}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ElevatedCard}" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRFCsClicked" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="4,Auto,*,Auto" ColumnSpacing="12">
                            <BoxView Grid.Column="0"
                                     BackgroundColor="{toolkit:AppThemeResource Primary}"
                                     WidthRequest="4" CornerRadius="2"
                                     VerticalOptions="Fill" />
                            <Label Grid.Column="1"
                                   Text="{x:Static f:FluentUI.tag_24_regular}"
                                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                                   FontSize="22"
                                   TextColor="{toolkit:AppThemeResource Icon}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="RFCs"
                                   Style="{StaticResource Body1}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="3"
                                   Text="{x:Static f:FluentUI.chevron_right_20_regular}"
                                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                                   FontSize="16"
                                   TextColor="{toolkit:AppThemeResource SecondaryText}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ElevatedCard}" Padding="14,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnContrasenaClicked" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="4,Auto,*,Auto" ColumnSpacing="12">
                            <BoxView Grid.Column="0"
                                     BackgroundColor="{toolkit:AppThemeResource Primary}"
                                     WidthRequest="4" CornerRadius="2"
                                     VerticalOptions="Fill" />
                            <Label Grid.Column="1"
                                   Text="{x:Static f:FluentUI.key_24_regular}"
                                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                                   FontSize="22"
                                   TextColor="{toolkit:AppThemeResource Icon}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="Contraseña"
                                   Style="{StaticResource Body1}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="3"
                                   Text="{x:Static f:FluentUI.chevron_right_20_regular}"
                                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                                   FontSize="16"
                                   TextColor="{toolkit:AppThemeResource SecondaryText}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <BoxView Style="{StaticResource Divider}" Margin="0,6" />

                    <!-- ─── Items simples ─── -->
                    <VerticalStackLayout VerticalOptions="End" Padding="20">

                        <!--<Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Padding="4,10">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnConfiguracionClicked" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0"
                                   Text="{x:Static f:FluentUI.settings_24_regular}"
                                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                                   FontSize="22"
                                   TextColor="{toolkit:AppThemeResource Icon}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Configuración"
                                   Style="{StaticResource Body1}"
                                   VerticalOptions="Center" />
                        </Grid>-->
                        <!--<BoxView Style="{StaticResource Divider}" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Padding="4,10">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDiagnosticoClicked" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0"
                                   Text="{x:Static f:FluentUI.heart_pulse_24_regular}"
                                   FontFamily="{x:Static f:FluentUI.FontFamily}"
                                   FontSize="22"
                                   TextColor="{toolkit:AppThemeResource Icon}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Diagnostico"
                                   Style="{StaticResource Body1}"
                                   VerticalOptions="Center" />
                        </Grid>
                        <BoxView Style="{StaticResource Divider}" />-->

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <!-- ── FOOTER ── -->
            <VerticalStackLayout Grid.Row="2" Padding="16,8,16,24" Spacing="12">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Padding="4,10">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAcercaDeClicked" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="{x:Static f:FluentUI.info_24_regular}"
                           FontFamily="{x:Static f:FluentUI.FontFamily}"
                           FontSize="22"
                           TextColor="{toolkit:AppThemeResource Icon}"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Acerca de"
                           Style="{StaticResource Body1}"
                           VerticalOptions="Center" />
                </Grid>

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Padding="4,10">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCompartirClicked" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="{x:Static f:FluentUI.share_24_regular}"
                           FontFamily="{x:Static f:FluentUI.FontFamily}"
                           FontSize="22"
                           TextColor="{toolkit:AppThemeResource Icon}"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Compartir Contabee"
                           Style="{StaticResource Body1}"
                           VerticalOptions="Center" />
                </Grid>

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Padding="4,10">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBuzonClicked" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="{x:Static f:FluentUI.mail_24_regular}"
                           FontFamily="{x:Static f:FluentUI.FontFamily}"
                           FontSize="22"
                           TextColor="{toolkit:AppThemeResource Icon}"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Buzón de sugerencias"
                           Style="{StaticResource Body1}"
                           VerticalOptions="Center" />
                </Grid>

                <BoxView Style="{StaticResource Divider}" />

                <!-- Toggle tema oscuro/claro -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Label Grid.Column="0"
                           Text="{x:Static f:FluentUI.weather_moon_28_regular}"
                           FontFamily="{x:Static f:FluentUI.FontFamily}"
                           FontSize="22"
                           TextColor="{toolkit:AppThemeResource Icon}"
                           VerticalOptions="Center" />
                    <Switch Grid.Column="1"
                            x:Name="ThemeSwitch"
                            HorizontalOptions="Center"
                            ThumbColor="{toolkit:AppThemeResource Primary}"
                            OnColor="{toolkit:AppThemeResource Alternate}"
                            Toggled="OnThemeSwitchToggled" />
                    <Label Grid.Column="2"
                           Text="{x:Static f:FluentUI.weather_sunny_28_regular}"
                           FontFamily="{x:Static f:FluentUI.FontFamily}"
                           FontSize="22"
                           TextColor="{toolkit:AppThemeResource Icon}"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Botón Cerrar Sesión -->
                <Button Text="Cerrar Sesion"
                        Style="{StaticResource PrimaryButton}"
                        Clicked="OnCerrarSesionClicked" />
            </VerticalStackLayout>

        </Grid>
    </Shell.FlyoutContent>

    <!-- ══════════════════════════════════════════ -->
    <!--  TABS DE NAVEGACIÓN INFERIOR               -->
    <!-- ══════════════════════════════════════════ -->
    <TabBar>
        <ShellContent
            Title="Inicio"
            Icon="{mi:Material Icon=Home}"
            ContentTemplate="{DataTemplate pages:DashboardPage}"
            Route="dashboard" />

        <ShellContent
            Title="Facturación"
            Icon="{mi:Material Icon=Receipt}"
            ContentTemplate="{DataTemplate pages:FacturacionPage}"
            Route="facturacion" />

        <!--<ShellContent
            Title="Equipo"
            Icon="{mi:Material Icon=Group}"
            ContentTemplate="{DataTemplate pages:EquipoPage}"
            Route="equipo" />-->
    </TabBar>

</Shell>
