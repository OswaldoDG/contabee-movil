<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- ========================================= -->
    <!-- BASE COLORS (primitivos, no cambian)      -->
    <!-- ========================================= -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="OffBlack">#141414</Color>

    <!-- ========================================= -->
    <!-- GRAY SCALE                                -->
    <!-- ========================================= -->
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- ========================================= -->
    <!-- BRAND COLORS                              -->
    <!-- Light  → tema claro                       -->
    <!-- Dark   → tema oscuro                      -->
    <!-- ========================================= -->
    <toolkit:AppThemeColor x:Key="Primary"   Light="#fec001" Dark="#fec001" />
    <toolkit:AppThemeColor x:Key="Secondary" Light="#ce8509" Dark="#ce8509" />
    <toolkit:AppThemeColor x:Key="Tertiary"  Light="#ce8509" Dark="#7a7a7a" />
    <toolkit:AppThemeColor x:Key="Alternate" Light="#f2f1f0" Dark="#3a3a3a" />

    <!-- ========================================= -->
    <!-- TEXT COLORS                               -->
    <!-- ========================================= -->
    <toolkit:AppThemeColor x:Key="PrimaryText"   Light="#1e1e1e" Dark="#fefdfc" />
    <toolkit:AppThemeColor x:Key="SecondaryText" Light="#6e6e6e" Dark="#b0b0b0" />

    <!-- ========================================= -->
    <!-- BACKGROUND COLORS                         -->
    <!-- ========================================= -->
    <toolkit:AppThemeColor x:Key="Background"          Light="#fefdfc" Dark="#141414" />
    <toolkit:AppThemeColor x:Key="SecondaryBackground" Light="#fafafa" Dark="#505050" />

    <!-- ========================================= -->
    <!-- ACCENT COLORS                             -->
    <!-- ========================================= -->
    <toolkit:AppThemeColor x:Key="Accent1" Light="#d8d9db" Dark="#7a7a7a" />
    <toolkit:AppThemeColor x:Key="Accent2" Light="#1e1e1e" Dark="#ffffff" />
    <toolkit:AppThemeColor x:Key="Accent3" Light="#fefdfc" Dark="#d8d9db" />
    <toolkit:AppThemeColor x:Key="Accent4" Light="#c5902b" Dark="#c5902b" />

    <!-- ========================================= -->
    <!-- SEMANTIC COLORS                           -->
    <!-- ========================================= -->
    <toolkit:AppThemeColor x:Key="Success" Light="#3c8c7b" Dark="#59b6a3" />
    <toolkit:AppThemeColor x:Key="Error"   Light="#d65c5c" Dark="#e57373" />
    <toolkit:AppThemeColor x:Key="Warning" Light="#e5c93d" Dark="#f1d859" />
    <toolkit:AppThemeColor x:Key="Info"    Light="#ffffff" Dark="#ffffff" />

    <!-- ========================================= -->
    <!-- CUSTOM COLORS                             -->
    <!-- ========================================= -->
    <toolkit:AppThemeColor x:Key="Shadow"          Light="#5e000000" Dark="#b3000000"  />
    <toolkit:AppThemeColor x:Key="ShadowSecondary" Light="#10000000" Dark="#232323"  />
    <toolkit:AppThemeColor x:Key="Icon"            Light="#000000"   Dark="#f2f1f0"  />
    <toolkit:AppThemeColor x:Key="Disabled"        Light="#e3e3e5"   Dark="#3a3a3a"  />
    <toolkit:AppThemeColor x:Key="Camera"          Light="#8f8f8f"   Dark="#8f8f8f"  />
    <toolkit:AppThemeColor x:Key="AppBarPrimary"   Light="#fefdfc"   Dark="#3a3a3a"  />
    <toolkit:AppThemeColor x:Key="AppBarSecondary" Light="#f4c611"   Dark="#ce8509"  />
    <toolkit:AppThemeColor x:Key="CardBackground" Light="#ffffff" Dark="#1E1E1E" />

    <!-- ========================================= -->
    <!-- BRUSHES                                   -->
    <!-- Los brushes usan AppThemeResource         -->
    <!-- porque Color ya es AppThemeColor          -->
    <!-- ========================================= -->
    <!--<SolidColorBrush x:Key="PrimaryBrush"   Color="{toolkit:AppThemeResource Primary}"   />
